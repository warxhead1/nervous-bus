def _esc_is_alt_sequence(poll_fn, read_fn, *, poll_timeout: float = 0.05,
                          drain_bytes: int = 8) -> bool:
    """Decide whether a just-read ESC byte is part of an Alt+X / CSI escape.

    Called immediately after reading a `\\x1b` byte from a raw-mode stdin.
    If a follow-up byte arrives within ``poll_timeout`` seconds, this is an
    Alt+X or CSI sequence — drain up to ``drain_bytes`` more bytes and
    return True (caller should NOT quit). If no follow-up arrives, ESC was
    pressed alone — return False (caller should quit).

    ``poll_fn(timeout)`` returns True iff at least one byte is readable
    within ``timeout`` seconds. ``read_fn(n)`` reads up to n bytes
    (best-effort). Pure function — no globals, no I/O setup. Designed to
    be unit-tested with simple lambdas / Mock objects.
    """
    if not poll_fn(poll_timeout):
        return False  # bare ESC → quit
    try:
        read_fn(drain_bytes)
    except OSError:
        pass
    return True  # Alt/CSI sequence → swallow


def _matches_glob(text: str, glob: str) -> bool:
    """Return True if text matches glob pattern (fnmatch-style). Empty glob = always match."""
    if not glob:
        return True
    return fnmatch.fnmatch(text, glob)


# Family rollup keys for the rates panel — group noisy sub-channels
def channel_family(chan: str) -> str:
    for prefix in (
        "agent.session",
        "deer-flow.stack-tuner",
        "deer-flow.metaprobe",
        "deer-flow.audit",
        "loom.lifecycle",
        "loom.plan",
        "loom.coord",
        "loom.runner",
        "bus.bead",
        "tengine.session",
        "tengine.code",
        "hearth.device",
        "hearth.router",
        "shell.command",
    ):
        if chan.startswith(prefix):
            return prefix
    if chan == "bus.dead_letter":
        return "bus.dead_letter"
    return chan


# ─── alert kinds (decay + balance against post-fix successes) ──────────────
@dataclass
class AlertKind:
    """One distinct alert *kind* (not per-event). Tracks rolling failure +
    success-sibling counts so a fix that lands silences the alert without
    needing an explicit remediation event (Layer 1 of nervous-bus-w1h).
    Also tracks explicit remediation via bus.remediation.applied (gck)."""
    kind_tuple: Tuple[str, ...]
    severity_default: str               # 'warn' | 'error'
    label: str
    failures: Deque[float] = field(default_factory=lambda: deque(maxlen=500))
    successes: Deque[float] = field(default_factory=lambda: deque(maxlen=500))
    last_failure_ts: float = 0.0
    last_failure_msg: str = ""
    first_seen_ts: float = field(default_factory=time.time)
    last_was_regression: bool = False
    remediation_applied_at: float = 0.0   # epoch seconds — set when bus.remediation.applied fires
    remediation_window_s: int = 0         # expected_resolution_window_s from remediation event

    def severity(self, now: float) -> float:
        cutoff = now - ALERT_WINDOW_S
        f = sum(1 for t in self.failures if t >= cutoff)
        s = sum(1 for t in self.successes if t >= cutoff)
        return f / max(1, f + s)

    def status(self, now: float) -> str:
        sev = self.severity(now)
        age = now - self.last_failure_ts if self.last_failure_ts else 1e9
        if sev >= ALERT_SEV_LOUD:
            return "regressed_fx" if (self.remediation_applied_at > 0 and now - self.remediation_applied_at < self.remediation_window_s) else ("regressed" if self.last_was_regression else "active")
        if sev < ALERT_SEV_DIM and age > ALERT_RESOLVED_S:
            return "resolved"
        if age < ALERT_RESOLVED_S and sev < ALERT_SEV_LOUD:
            return "stabilizing_fx" if (self.remediation_applied_at > 0 and now - self.remediation_applied_at < self.remediation_window_s) else "stabilizing"
        return "active"


def derive_alert_kind(chan: str, data: dict) -> Optional[Tuple[Tuple, str, str]]:
    """If this event IS an alert, return (kind_tuple, severity_default, label).
    Otherwise None."""
    if chan == "bus.dead_letter":
        reason = data.get("failure_reason", "unknown")
        original = data.get("original_type", "?")
        return (("dlq", reason),
                "error",
                f"DLQ {reason} ← {original}")
    if chan.endswith("integrity.warn"):
        # Multi-field fallback for upstream-naming variation (3be folded in)
        issue = (data.get("issue") or data.get("signal")
                 or data.get("kind") or data.get("metric") or "unknown")
        stage = data.get("stage", "")
        model = data.get("model", "")
        kind_tuple = ("integrity.warn", stage, model, issue)
        label = f"integrity {issue}"
        if stage:
            label += f" @ {stage}"
        if model:
            label += f" ({model})"
        return (kind_tuple, "warn", label)
    return None


def matches_success(kind: AlertKind, chan: str, data: dict) -> bool:
    """Does this non-alert event count as a success-sibling for `kind`,
    silencing it via the rolling ratio?"""
    kt = kind.kind_tuple
    if kt[0] == "dlq":
        # Any successful publish on the original_type channel offsets this DLQ
        # entry's weight. We don't have a reliable original_type→success map,
        # so use the cheaper proxy: any non-DLQ event period.
        return chan != "bus.dead_letter"
    if kt[0] == "integrity.warn":
        _, stage, model, _ = kt
        # A successful stage.done for the SAME (stage, model) is concrete proof
        # the kind that was failing now isn't.
        if chan.endswith("stage.done") and data.get("ok", True):
            d_stage = data.get("stage", "")
            d_model = data.get("model", "")
            return d_stage == stage and d_model == model
    return False


class ThresholdStore:
    """Reads pattern:thresholds:{channel} from Redis; falls back to defaults."""
    _DEFAULT = {"warn_sigma": 2.0, "alert_sigma": 3.0}

    def __init__(self) -> None:
        self._thresholds: dict[str, dict] = {}
        self._r: Optional[object] = None
        self._last_refresh = 0.0
        try:
            if _redis_mod is None:
                return
            self._r = _redis_mod.Redis.from_url(
                "redis://localhost:6379", decode_responses=True,
                socket_timeout=1.0, socket_connect_timeout=1.0,
            )
            self._r.ping()
        except Exception:
            self._r = None

    def refresh(self) -> None:
        if not self._r:
            return
        now = time.time()
        if now - self._last_refresh < 60:
            return
        self._last_refresh = now
        try:
            keys = self._r.keys("pattern:thresholds:*")
            for key in keys:
                ch = key.removeprefix("pattern:thresholds:")
                raw = self._r.hgetall(key)
                self._thresholds[ch] = {
                    "warn_sigma": float(raw.get("warn_sigma", 2.0)),
                    "alert_sigma": float(raw.get("alert_sigma", 3.0)),
                }
        except Exception:
            pass

    def warn_sigma(self, channel: str) -> float:
        return self._thresholds.get(channel, self._DEFAULT)["warn_sigma"]

    def alert_sigma(self, channel: str) -> float:
        return self._thresholds.get(channel, self._DEFAULT)["alert_sigma"]


# ─── state ─────────────────────────────────────────────────────────────────
@dataclass
class State:
    log_path: Path
    fp: Optional[object] = None
    inode: Optional[int] = None

    started_at: float = field(default_factory=time.time)
    events_total: int = 0
    dead_letters_total: int = 0

    # rolling per-family bucket counts; outer dict family → deque[60]
    buckets: Dict[str, Deque[int]] = field(default_factory=dict)
    last_bucket_epoch: int = 0

    # live event stream
    stream: Deque[dict] = field(default_factory=lambda: deque(maxlen=MAX_STREAM))

    # top talkers
    talkers: Counter = field(default_factory=Counter)

    # in-flight sagas: saga_id → {started_at, n_steps, last_event_type, last_event_at}
    sagas: Dict[str, dict] = field(default_factory=dict)

    # silent-channel detection (nervous-bus-tk3)
    expected_channels: set = field(default_factory=set)  # from schemas/
    seen_channels:     set = field(default_factory=set)  # ever observed in log

    # alerts ring (raw stream, last N events for the bottom sub-table)
    alerts: Deque[dict] = field(default_factory=lambda: deque(maxlen=20))

    # alert kinds (grouped, status-aware) — primary alert view
    alert_kinds: Dict[Tuple, AlertKind] = field(default_factory=dict)

    # cumulative per-channel total
    chan_total: Counter = field(default_factory=Counter)

    # adaptive alert thresholds from Redis (pattern:thresholds:*)
    thresholds: ThresholdStore = field(default_factory=ThresholdStore)

    # Redis connection for pattern:annotations (panel_signals)
    _redis: Optional[Any] = field(default=None, init=False, repr=False)

    # per-channel fan-out latency tracking (channel → deque of microsecond deltas)
    # used to compute p50/p95 in the rates panel.
    chan_latencies: Dict[str, Deque[int]] = field(default_factory=dict)

    # explicit remediation registry: (kind_tuple,) → applied_at + window_s
    remediations: Dict[Tuple, dict] = field(default_factory=dict)

    # m9d: interactive filter/drill-down state
    filter_glob: str = ""           # glob pattern for / filter
    drill_channel: Optional[str] = None  # channel being drilled into (1-9 key)
    muted_channels: set = field(default_factory=set)
    zoom_idx: int = 1                # 0=5min, 1=1h (default), 2=24h
    BUCKET_SECONDS: int = 60        # current bucket size (runtime-tunable for zoom)
    NUM_BUCKETS: int = 60            # fixed at 60 buckets

    # kwu: per-channel subscriber counts from bus.subscribers.snapshot
    chan_subscribers: Dict[str, int] = field(default_factory=dict)

    # deprecated field removed — keep for dataclass API compat
    _reserved: Optional[Any] = field(default=None, init=False, repr=False)

    def ensure_buckets(self, family: str) -> Deque[int]:
        if family not in self.buckets:
            self.buckets[family] = deque([0] * NUM_BUCKETS, maxlen=NUM_BUCKETS)
        return self.buckets[family]

    def roll_buckets_to(self, now_epoch: int) -> None:
        """Advance bucket window if we've crossed bucket boundaries."""
        cur_bucket = now_epoch // BUCKET_SECONDS
        if self.last_bucket_epoch == 0:
            self.last_bucket_epoch = cur_bucket
            return
        steps = cur_bucket - self.last_bucket_epoch
        if steps <= 0:
            return
        steps = min(steps, NUM_BUCKETS)
        for _ in range(steps):
            for fam in list(self.buckets):
                self.buckets[fam].append(0)
        self.last_bucket_epoch = cur_bucket


# ─── log tailing with inode-rotation detect ────────────────────────────────
def open_log(state: State) -> None:
    if state.fp is not None:
        try: state.fp.close()
        except Exception: pass
    if not state.log_path.exists():
        state.fp = None
        state.inode = None
        return
    state.fp = state.log_path.open("r", encoding="utf-8", errors="replace")
    state.fp.seek(0, os.SEEK_END)  # tail-follow from current end
    state.inode = state.log_path.stat().st_ino


def check_rotation(state: State) -> None:
    """Reopen if file was rotated (inode changed) or shrank (truncated)."""
    if not state.log_path.exists():
        if state.fp is not None:
            state.fp.close()
            state.fp = None
        return
    st = state.log_path.stat()
    if state.fp is None or st.st_ino != state.inode:
        # fresh file or rotated — reopen but seek to BEGINNING (we missed nothing
        # because we just opened it). For inode change mid-run, also start fresh.
        if state.fp is not None:
            try: state.fp.close()
            except Exception: pass
        state.fp = state.log_path.open("r", encoding="utf-8", errors="replace")
        state.inode = st.st_ino
        return
    # truncation: position past end means file got smaller
    if state.fp.tell() > st.st_size:
        state.fp.seek(0)


def read_new_lines(state: State) -> List[str]:
    if state.fp is None:
        open_log(state)
        return []
    check_rotation(state)
    if state.fp is None:
        return []
    out: List[str] = []
    while True:
        line = state.fp.readline()
        if not line:
            break
        line = line.strip()
        if line:
            out.append(line)
    return out


# ─── ingestion ─────────────────────────────────────────────────────────────
def _event_epoch(e: dict) -> int:
    t = e.get("time") or ""
    if not t:
        return 0
    try:
        return int(datetime.fromisoformat(t.replace("Z", "+00:00")).timestamp())
    except Exception:
        return 0


def _project_label(e: dict) -> str:
    # data.project is the semantically meaningful project the event is *about*.
    # Fall back to source basename only when it is missing, empty, or 'unknown'
    # (loomies emit 'unknown' until nervous-bus-l8u lands upstream).
    data = e.get("data") or {}
    proj = data.get("project") if isinstance(data, dict) else None
    if proj and proj != "unknown":
        return str(proj)
    return (e.get("source") or "").lstrip("/").split("/")[0] or "?"


def ingest_event(state: State, raw: str, *, historical: bool = False) -> None:
    try:
        e = json.loads(raw)
    except Exception:
        return
    chan = e.get("type") or "unknown"
    src = _project_label(e)
    family = channel_family(chan)

    state.events_total += 1
    state.chan_total[chan] += 1
    state.talkers[(src, family)] += 1
    state.seen_channels.add(chan)

    # ── latency tracking (noj): data._bus.received_at is epoch microseconds ──
    data = e.get("data") or {}
    if isinstance(data, dict):
        bus = data.get("_bus", {})
        if isinstance(bus, dict):
            received_at = bus.get("received_at")
            if received_at is not None:
                try:
                    rec_us = int(received_at)
                    now_us = int(time.time() * 1_000_000)
                    latency_us = max(0, now_us - rec_us)
                    latencies = state.chan_latencies.setdefault(chan, deque(maxlen=200))
                    latencies.append(latency_us)
                except (ValueError, TypeError):
                    pass
            # delivered_at stamps the SSE fan-out; track it too for p50/p95
            delivered_at = bus.get("delivered_at")
            if delivered_at is not None:
                try:
                    del_us = int(delivered_at)
                    now_us = int(time.time() * 1_000_000)
                    fanout_us = max(0, del_us - rec_us) if received_at else 0
                    latencies = state.chan_latencies.setdefault(chan, deque(maxlen=200))
                    latencies.append(fanout_us)
                except (ValueError, TypeError):
                    pass

    # ── kwu: subscriber snapshot tracking ─────────────────────────────────────
    if chan == "bus.subscribers.snapshot":
        subs_data = data if isinstance(data, dict) else {}
        for ch, ids_val in subs_data.items():
            if isinstance(ids_val, list):
                state.chan_subscribers[str(ch)] = len(ids_val)

    # ── explicit remediation registry (gck): stamp AlertKind state ──────────────
    if chan == "bus.remediation.applied":
        kt_data = data.get("targets_pathology", {}).get("kind")
        if kt_data:
            kind_tuple = tuple(kt_data) if isinstance(kt_data, list) else (kt_data,)
            applied_at_str = data.get("applied_at", "")
            try:
                import datetime
                rem_applied_ts = datetime.datetime.fromisoformat(applied_at_str.replace("Z", "+00:00")).timestamp()
            except Exception:
                rem_applied_ts = time.time()
            rem_window_s = int(data.get("expected_resolution_window_s", 600) or 600)
            state.remediations[kind_tuple] = {
                "applied_at": applied_at_str,
                "window_s": rem_window_s,
                "fix_summary": data.get("fix_summary", ""),
                "applied_by": data.get("applied_by", ""),
            }
            # Propagate remediation into matching AlertKind so status() reflects it
            if kind_tuple in state.alert_kinds:
                ak = state.alert_kinds[kind_tuple]
                ak.remediation_applied_at = rem_applied_ts
                ak.remediation_window_s = rem_window_s

    # bucket count — if historical, place the event in its actual time bucket
    # so the sparklines reflect real history rather than a single big spike.
    bucket = state.ensure_buckets(family)
    if historical:
        ev_epoch = _event_epoch(e)
        if ev_epoch:
            now_bucket = int(time.time()) // BUCKET_SECONDS
            ev_bucket = ev_epoch // BUCKET_SECONDS
            offset = now_bucket - ev_bucket  # 0=current, NUM_BUCKETS-1=oldest
            if 0 <= offset < NUM_BUCKETS:
                idx = (NUM_BUCKETS - 1) - offset
                bucket[idx] += 1
    else:
        state.roll_buckets_to(int(time.time()))
        bucket[-1] += 1

    state.stream.append(e)

    # ── alerts: kind-grouped tracking with rolling success/failure decay ──
    #
    # Two-tier write path:
    #   1. If this event IS an alert, upsert the AlertKind, append failure ts,
    #      mark as regression if we'd previously declared this kind 'resolved'.
    #   2. Otherwise, scan known alert kinds and credit any whose success-sibling
    #      predicate matches THIS event (e.g. stage.done with same stage+model
    #      counts as a success against an integrity.warn alert kind).
    data = e.get("data") or {}
    now_ts = time.time() if not historical else (_event_epoch(e) or time.time())
    derived = derive_alert_kind(chan, data)
    if derived is not None:
        kind_tuple, sev_default, label = derived
        kind = state.alert_kinds.get(kind_tuple)
        if kind is None:
            kind = AlertKind(
                kind_tuple=kind_tuple,
                severity_default=sev_default,
                label=label,
            )
            state.alert_kinds[kind_tuple] = kind
        # mark regression if this kind had been resolved before this failure
        if kind.last_failure_ts and kind.status(now_ts) == "resolved":
            kind.last_was_regression = True
        kind.failures.append(now_ts)
        kind.last_failure_ts = now_ts
        kind.last_failure_msg = label
        if chan == "bus.dead_letter":
            state.dead_letters_total += 1
        # also append to raw stream for the bottom sub-table
        state.alerts.append({
            "severity": sev_default,
            "msg": label,
            "src_id": e.get("id", ""),
            "ts": e.get("time", ""),
        })
    else:
        # success-sibling credit for any alert kinds matching this event
        for kind in state.alert_kinds.values():
            if matches_success(kind, chan, data):
                kind.successes.append(now_ts)
                # crossing into low-severity territory clears regression flag
                if kind.last_was_regression and kind.severity(now_ts) < ALERT_SEV_DIM:
                    kind.last_was_regression = False

    # saga tracking
    data = e.get("data") or {}
    saga_id = data.get("saga_id") or data.get("cycle_id")
    if saga_id:
        s = state.sagas.get(saga_id)
        if s is None:
            # Only OPEN a saga on an explicit start event (prevents
            # audit.recommendation/.cycle and other mid-flight events with
            # cycle_id from creating zombies that never terminate).
            is_start = (chan.endswith(".start")
                        or chan.endswith(".cycle.start")
                        or chan.endswith(".opened")
                        or chan.endswith(".created"))
            if SAGA_REQUIRE_START and not is_start:
                pass  # ignore — saga must be explicitly opened
            else:
                state.sagas[saga_id] = {
                    "started_at": e.get("time",""),
                    "n_steps": 1,
                    "last_event_type": chan,
                    "last_event_at": e.get("time",""),
                    "last_event_ts": time.time(),
                }
        else:
            s["n_steps"] += 1
            s["last_event_type"] = chan
            s["last_event_at"] = e.get("time","")
            s["last_event_ts"] = time.time()
        # terminal events close the saga (any of: explicit .done/.closed,
        # .pr_opened, or the metaprobe.cycle terminal that fires once-per-cycle)
        if (chan.endswith(".cycle.done")
                or chan.endswith(".closed")
                or chan.endswith(".pr_opened")
                or chan == "deer-flow.metaprobe.cycle"):
            state.sagas.pop(saga_id, None)

    # Age-out: drop sagas idle past SAGA_KILL_S. Cheap O(N), N is small.
    if state.sagas:
        now_ts = time.time()
        dead = [sid for sid, s in state.sagas.items()
                if (now_ts - s["last_event_ts"]) > SAGA_KILL_S]
        for sid in dead:
            state.sagas.pop(sid, None)


# ─── silent-channel detection (nervous-bus-tk3) ───────────────────────────
def load_expected_channels(schemas_dir: Path) -> set:
    """Derive expected channel names from schemas/*.v*.json filenames.
    Strips the .v<n>.json suffix; '.start'/'.done'/'.opened'/'.closed' lifecycle
    suffixes are kept as separate channels (a schema for the family is enough
    to count any of its lifecycle variants as 'covered'). Internal dashboard
    schemas (bus.dashboard, bus.saga, bus.redis-mirror.config) are excluded —
    they're config artifacts, not bus events that publishers emit.
    """
    if not schemas_dir.exists():
        return set()
    expected = set()
    EXCLUDE_PREFIXES = ("bus.dashboard", "bus.saga", "bus.redis-mirror")
    import re
    for f in schemas_dir.glob("*.v*.json"):
        name = f.stem  # e.g. agent.session.v1
        chan = re.sub(r"\.v\d+$", "", name)
        if any(chan.startswith(p) for p in EXCLUDE_PREFIXES):
            continue
        expected.add(chan)
    return expected


# ─── rendering ─────────────────────────────────────────────────────────────
def sparkline(buckets: Deque[int], width: int = 24) -> Text:
    pts = list(buckets)[-width:]
    if not pts or max(pts) == 0:
        return Text("─" * width, style="dim")
    peak = max(pts)
    out = Text()
    for v in pts:
        if v == 0:
            out.append("▁", style="dim")
        else:
            idx = min(7, max(0, int((v / peak) * 7)))
            # heat-style coloring: low=green, mid=yellow, high=red
            style = "green" if idx < 3 else ("yellow" if idx < 6 else "bright_red")
            out.append(SPARK[idx], style=style)
    return out


def panel_rates(state: State) -> Panel:
    table = Table.grid(padding=(0, 1), expand=True)
    table.add_column("channel", ratio=3, no_wrap=True, overflow="ellipsis")
    table.add_column("spark",   ratio=2)
    table.add_column("rate",    width=8,  justify="right")
    table.add_column("p50/p95", width=12, justify="right")
    table.add_column("total",   width=7,  justify="right")

    def latency_str(chan: str) -> str:
        lats = state.chan_latencies.get(chan)
        if not lats or len(lats) < 3:
            return ""
        sorted_lats = sorted(lats)
        n = len(sorted_lats)
        p50 = sorted_lats[n // 2]
        p95 = sorted_lats[int(n * 0.95)]
        if p50 >= 1000:
            return f"{p50/1000:.0f}ms/{p95/1000:.0f}ms"
        return f"{p50}µs/{p95}µs"

    def _tier_sep(label: str, summary: str = "") -> None:
        table.add_row(
            Text.assemble(Text("── ", style="dim"), Text(label, style="bold")),
            Text(""),
            Text(summary, style="dim"),
            Text(""),
            Text(""),
        )

    def _add_row(fam: str, buf, recent: int, total: int, rate: float) -> None:
        col = channel_color(fam)
        display = fam if len(fam) <= 35 else fam[:32] + "…"
        lat_str = latency_str(fam)
        table.add_row(
            Text(display, style=col),
            sparkline(buf),
            Text(f"{rate:>4.1f}/m", style="bold" if recent else "dim"),
            Text(lat_str, style="cyan" if lat_str else "dim"),
            Text(str(total), style="dim"),
        )

    # Build all rows, sorted by recency then volume
    rows = []
    for fam, buf in state.buckets.items():
        if not _matches_glob(fam, state.filter_glob):
            continue
        recent = sum(list(buf)[-5:])
        total  = sum(buf)
        rate   = total / max(1, len(buf))
        rows.append((fam, buf, recent, total, rate))
    rows.sort(key=lambda r: (-r[2], -r[3]))

    if not rows:
        table.add_row(Text("(no events yet)", style="dim"), "", "", "", "")
        return Panel(table, title="[bold]channel rates[/]  [dim](last 60m)[/]",
                     border_style="cyan", padding=(0, 1))

    # Tier split: market (high-freq signal data) / ops / dlq
    market_rows = [r for r in rows if any(r[0].startswith(p) for p in _MARKET_PREFIXES)]
    dlq_rows    = [r for r in rows if r[0] == "bus.dead_letter"]
    ops_rows    = [r for r in rows if r not in market_rows and r not in dlq_rows]

    # ── 📈 market tier ──────────────────────────────────────────────────────
    if market_rows:
        m_rate   = sum(r[4] for r in market_rows)
        m_recent = any(r[2] > 0 for r in market_rows)
        _tier_sep("📈 market", f"{m_rate:.0f}/m" if m_recent else "quiet")
        for row in market_rows:
            _add_row(*row)

    # ── ⚙  ops tier ─────────────────────────────────────────────────────────
    if ops_rows:
        o_rate = sum(r[4] for r in ops_rows)
        _tier_sep("⚙  ops", f"{o_rate:.1f}/m")
        for row in ops_rows[:10]:
            _add_row(*row)
        if len(ops_rows) > 10:
            table.add_row(
                Text(f"  +{len(ops_rows)-10} more channels", style="dim italic"),
                Text(""), Text(""), Text(""), Text(""),
            )

    # ── ☠  dlq tier — use alert_kinds for richer status ─────────────────────
    now = time.time()
    dlq_kinds = sorted(
        [ak for ak in state.alert_kinds.values() if ak.kind_tuple[0] == "dlq"],
        key=lambda k: -k.last_failure_ts,
    )
    if dlq_kinds or dlq_rows:
        total_dlq = state.dead_letters_total
        _tier_sep("☠  dlq", f"{total_dlq} total" if total_dlq else "")
        if dlq_kinds:
            for ak in dlq_kinds[:6]:
                status = ak.status(now)
                color = (
                    "bright_red" if status in ("active", "regressed", "regressed_fx")
                    else ("yellow" if status.startswith("stabilizing") else "dim")
                )
                n_recent = sum(1 for t in ak.failures if now - t < 3600)
                age_s    = now - ak.last_failure_ts
                age_str  = (f"{int(age_s//60)}m" if age_s >= 60 else f"{int(age_s)}s") + " ago"
                label    = ak.label[:40] if len(ak.label) <= 40 else ak.label[:37] + "…"
                table.add_row(
                    Text(label, style=color),
                    Text(""),
                    Text(f"{n_recent}/h", style=color),
                    Text(age_str, style="dim"),
                    Text(str(len(ak.failures)), style="dim"),
                )
        else:
            for row in dlq_rows:
                _add_row(*row)

    n_chans = len(rows)
    return Panel(table, title=f"[bold]channel rates[/]  [dim](last 60m · {n_chans} chans)[/]",
                 border_style="cyan", padding=(0, 1))


def panel_talkers(state: State) -> Panel:
