_MAX_MARKET_IN_STREAM = 4   # cap tachyonos slots in the stream default view

def panel_stream(state: State) -> Panel:
    table = Table.grid(padding=(0, 1), expand=True)
    table.add_column("ts",      width=8)
    table.add_column("channel", width=22, no_wrap=True, overflow="ellipsis")
    table.add_column("source",  width=10, no_wrap=True)
    table.add_column("summary", overflow="ellipsis", no_wrap=True, ratio=1)

    if not state.stream:
        table.add_row(Text("waiting for events…", style="dim"), "", "", "")
        return Panel(table, title="[bold]live stream[/]  [dim](last 30 events)[/]",
                     border_style="green", padding=(0, 1))

    all_events = list(state.stream)

    if state.filter_glob:
        display = [e for e in all_events if _matches_glob(e.get("type", "?"), state.filter_glob)]
    else:
        # Balance: ops events fill most slots; market gets a small capped slice
        def _is_market(e: dict) -> bool:
            return any(e.get("type", "").startswith(p) for p in _MARKET_PREFIXES)
        ops    = [e for e in all_events if not _is_market(e)]
        market = [e for e in all_events if _is_market(e)]
        n_mkt  = min(_MAX_MARKET_IN_STREAM, len(market))
        n_ops  = min(MAX_STREAM - n_mkt, len(ops))
        display = sorted(ops[-n_ops:] + market[-n_mkt:], key=lambda e: e.get("time", ""))

    for e in display:
        chan = e.get("type", "?")
        col  = channel_color(chan)
        t    = _local_hms(e.get("time", "") or "")
        src  = _project_label(e)[:10]
        summary = _summarize(chan, e.get("data") or {})
        table.add_row(
            Text(t, style="dim"),
            Text(chan, style=col),
            Text(src, style="dim"),
            Text(summary),
        )
    mkt_count = sum(1 for e in all_events if any(e.get("type","").startswith(p) for p in _MARKET_PREFIXES))
    title_suffix = f"  [dim](+{mkt_count} market)[/]" if mkt_count and not state.filter_glob else ""
    return Panel(table, title=f"[bold]live stream[/]  [dim](last 30 events)[/]{title_suffix}",
                 border_style="green", padding=(0, 1))


def _summarize(chan: str, data: dict) -> str:
    if not isinstance(data, dict):
        return str(data)[:60]
    interesting = [
        "bead_id", "fps", "event", "signal", "failure_reason", "agent",
        "score", "pr_url", "project", "verdict", "stage",
    ]
    parts = []
    for k in interesting:
        v = data.get(k)
        if v in (None, "", "unknown"):
            continue
        sv = str(v)
        if len(sv) > 30:
            sv = sv[:30] + "…"
        parts.append(f"{k}={sv}")
        if len(parts) >= 3:
            break
    return "  ".join(parts)


def panel_alerts(state: State) -> Panel:
    parts = []

    # in-flight sagas (top of pane)
    if state.sagas:
        sag_table = Table.grid(padding=(0, 1), expand=True)
        sag_table.add_column("saga", overflow="ellipsis", no_wrap=True)
        sag_table.add_column("steps", justify="right")
        sag_table.add_column("age",   justify="right")
        sag_table.add_column("last",  overflow="ellipsis", no_wrap=True)
        now = time.time()
        sag_rows = sorted(state.sagas.items(),
                          key=lambda kv: -kv[1]["last_event_ts"])[:6]
        for sid, s in sag_rows:
            age = int(now - s["last_event_ts"])
            age_str = f"{age}s" if age < 60 else f"{age//60}m"
            stale = age > SAGA_STALE_S
            style = "dim" if stale else "white"
            sag_table.add_row(
                Text(sid[:14], style="green" if not stale else "dim"),
                Text(str(s["n_steps"]), style=style),
                Text(age_str, style="bright_red" if stale else style),
                Text(s["last_event_type"], style=channel_color(s["last_event_type"])),
            )
        parts.append(Panel(sag_table, title="[bold]in-flight sagas[/]",
                           border_style="bright_blue", padding=(0, 1)))
    else:
        parts.append(Panel(Text("(no sagas in flight)", style="dim"),
                           title="[bold]in-flight sagas[/]", border_style="dim",
                           padding=(0, 1)))

    # alert kinds (grouped, status-aware) — primary view.
    # Layout: status+age FIRST so they're never clipped at narrow widths,
    # kind label LAST with ellipsis. Counts collapsed into the label.
    now = time.time()
    al_table = Table.grid(padding=(0, 1), expand=True)
    al_table.add_column("status_age", width=12, no_wrap=True)
    al_table.add_column("kind",        overflow="ellipsis", no_wrap=True)

    if state.alert_kinds:
        ordered = sorted(
            state.alert_kinds.values(),
            key=lambda k: (
                {"regressed": 0, "active": 1, "stabilizing": 2, "resolved": 3}
                .get(k.status(now), 4),
                -k.last_failure_ts,
            ),
        )
        visible = []
        resolved_overflow = 0
        for k in ordered:
            st = k.status(now)
            if st == "resolved" and len(visible) >= 6:
                resolved_overflow += 1
                continue
            visible.append(k)

        status_styles = {
            "regressed":      ("REGR",  "bright_red"),
            "regressed_fx":   ("REGR-FX","bright_red bold"),
            "active":         ("ACT ",  "yellow"),
            "stabilizing":    ("STAB",  "cyan"),
            "stabilizing_fx": ("STAB-FX","cyan bold"),
            "resolved":       ("RES ",  "dim"),
        }
        for k in visible:
            st = k.status(now)
            st_label, st_color = status_styles.get(st, ("?   ", "dim"))
            cutoff = now - ALERT_WINDOW_S
            f = sum(1 for t in k.failures if t >= cutoff)
            s = sum(1 for t in k.successes if t >= cutoff)
            age = int(now - k.last_failure_ts) if k.last_failure_ts else 0
            age_str = f"{age}s" if age < 60 else (f"{age//60}m" if age < 3600 else f"{age//3600}h")
            row_style = "dim" if st == "resolved" else ""
            # status_age cell: badge + age in a single fixed-width cell
            sa = Text()
            sa.append(st_label, style=f"bold {st_color}")
            sa.append(f" {age_str:>4}", style=row_style or "dim")
            label_with_counts = f"{k.label}  [f={f} s={s}]"
            al_table.add_row(
                sa,
                Text(label_with_counts, style=row_style or "white"),
            )
        if resolved_overflow:
            al_table.add_row(
                Text("…", style="dim"),
                Text(f"+{resolved_overflow} more resolved", style="dim italic"),
            )
    else:
        al_table.add_row(
            Text("CLN     -", style="bold green"),
            Text("clean — no alert kinds", style="green"),
        )
    parts.append(Panel(al_table, title="[bold]alerts[/]  [dim](decay=ratio)[/]",
                       border_style="red", padding=(0, 1)))

    # Silent-channel detection (nervous-bus-tk3) — channels with a schema
    # but never observed in the dashboard's lifetime. A schema for "X" is
    # satisfied by either an "X" or "X.v<n>" channel actually being emitted
    # (publishers vary in whether they include the version suffix in the
    # channel name; both are legitimate).
    if state.expected_channels:
        import re
        seen_stripped = {re.sub(r"\.v\d+$", "", c) for c in state.seen_channels}
        silent = sorted(state.expected_channels - state.seen_channels - seen_stripped)
        sc_table = Table.grid(padding=(0, 1), expand=True)
        sc_table.add_column("channel", overflow="ellipsis", no_wrap=True)
        sc_table.add_column("subs", justify="right", style="dim")
        if silent:
            for chan in silent[:8]:
                n_subs = state.chan_subscribers.get(chan, 0)
                subs_str = f"[{n_subs}]" if n_subs > 0 else ""
                warn = "yellow" if n_subs > 0 else "dim"
                sc_table.add_row(Text(chan, style=warn), Text(subs_str, style="dim"))
            if len(silent) > 8:
                sc_table.add_row(Text(f"+{len(silent)-8} more", style="dim italic"))
            title = f"[bold]silent channels[/]  [dim]({len(silent)}/{len(state.expected_channels)})[/]"
            border = "yellow"
        else:
            sc_table.add_row(Text("all schema'd channels active",
                                  style="green"))
            title = f"[bold]silent channels[/]  [dim](0/{len(state.expected_channels)})[/]"
            border = "dim"
        parts.append(Panel(sc_table, title=title, border_style=border,
                           padding=(0, 1)))

    return Panel(Group(*parts), border_style="dim", padding=0,
                 title="[bold]signals[/]")


def panel_footer(state: State, tick_s: float, current_tab: int = 1) -> Panel:
    uptime = int(time.time() - state.started_at)
    up_str = f"{uptime//3600}h{(uptime%3600)//60:02d}m" if uptime >= 3600 else f"{uptime//60:02d}m{uptime%60:02d}s"

    TABS = [(1, "bus"), (2, "sysmap"), (3, "agents"), (4, "loomies")]
    tab_text = Text()
    for num, name in TABS:
        if num == current_tab:
            tab_text.append(f"  [{num}] ", style="dim")
            tab_text.append(name, style="bold blue")
            tab_text.append(" ●", style="bold blue")
        else:
            tab_text.append(f"  [{num}] {name}", style="dim")
    tab_text.append("   │  [q] quit   │  ", style="dim")

    stats = Text()
    stats.append(f"ev {state.events_total}  ", style="dim")
    stats.append(f"ch {len(state.chan_total)}  ", style="dim")
    stats.append(f"DLQ {state.dead_letters_total}  ",
                 style="bright_red" if state.dead_letters_total else "dim")
    stats.append(f"tick {tick_s:.1f}s  up {up_str}", style="dim")

    return Panel(Text.assemble(tab_text, stats), border_style="dim", padding=(0, 1))


def _cluster_annotations(anns: list[dict], window_s: int = 300) -> list[list[dict]]:
    if not anns:
        return []
    clusters: list[list[dict]] = []
    current: list[dict] = [anns[0]]
    current_end_ts = current[0].get("ts", 0)
    for ann in anns[1:]:
        ann_ts = ann.get("ts", 0)
        if current_end_ts - ann_ts <= window_s:
            current.append(ann)
            current_end_ts = ann_ts
        else:
            clusters.append(current)
            current = [ann]
            current_end_ts = ann_ts
    clusters.append(current)
    return clusters


def panel_signals(state: "State") -> Panel:
    """Read pattern:annotations from Redis, show 6 most recent signals with temporal clustering."""
    t = Table.grid(padding=(0, 1))
    t.add_column(width=10)
    t.add_column(width=9)
    t.add_column(width=5)
    t.add_column()

    _STYPE_COLORS = {
        "anomaly":     "bright_red",
        "pattern":     "yellow",
        "correlation": "cyan",
        "silence":     "magenta",
        "recovery":    "green",
    }
    _SEV_COLORS = {"info": "dim", "warn": "yellow", "alert": "bright_red", "critical": "red bold"}

    annotations: list[dict] = []
    if state._redis is not None:
        try:
            raw_map = state._redis.hgetall("pattern:annotations")
            for v in raw_map.values():
                try:
                    annotations.append(json.loads(v))
                except Exception:
                    pass
        except Exception:
            pass

    clusters: list[list[dict]] = []
    if not annotations:
        t.add_row(Text("no signals yet", style="dim italic"), Text(""), Text(""), Text(""))
    else:
        # apply filter_glob to channel names in annotations
        fg = state.filter_glob
        if fg:
            annotations = [a for a in annotations
                           if any(_matches_glob(c, fg) for c in (a.get("channels") or []))]
        if not annotations:
            t.add_row(Text("(no signals match filter)", style="dim italic"), Text(""), Text(""), Text(""))
        else:
            annotations.sort(key=lambda x: x.get("ts", 0), reverse=True)
            clusters = _cluster_annotations(annotations, window_s=300)

        rows_needed = 0
        cluster_entries: list[tuple[list[dict], int]] = []
        for cluster in clusters:
            size = len(cluster)
            if size > 1:
                rows_for_cluster = 2 + min(size, max(0, 6 - rows_needed - 2))
            else:
                rows_for_cluster = min(size, max(0, 6 - rows_needed))
            if rows_needed >= 6:
                break
            if rows_for_cluster > 0:
                cluster_entries.append((cluster, rows_for_cluster))
                rows_needed += rows_for_cluster

        for cluster, alloc in cluster_entries:
            if len(cluster) > 1:
                t.add_row(
                    Text(f"  .-- {len(cluster)} signals --.", style="dim"),
                    Text(""), Text(""), Text(""),
                )
            for ann in cluster[:alloc - (2 if len(cluster) > 1 else 0)]:
                stype = ann.get("signal_type", "?")
                conf  = float(ann.get("confidence", 0))
                ch    = (ann.get("channels") or ["?"])[0].split(".")[-1][:10]
                desc  = (ann.get("description") or "")[:60]
                sev   = ann.get("severity", "info")
                bar   = "█" * int(conf * 5) + "░" * (5 - int(conf * 5))
                t.add_row(
                    Text(ch,    style="dim"),
                    Text(stype, style=_STYPE_COLORS.get(stype, "white")),
                    Text(bar,   style=_SEV_COLORS.get(sev, "white")),
                    Text(desc,  style="dim"),
                )
            if len(cluster) > 1:
                t.add_row(Text("  `--", style="dim"), Text(""), Text(""), Text(""))

    return Panel(t, title="[bold]signals[/]  [dim](pattern:annotations)[/]",
                 border_style="dim", padding=(0, 1))


def build_layout(state: State, tick_s: float, current_tab: int = 1) -> Layout:
    # Tab 2 — sysmap: delegate entirely to cc_sysmap renderer
    if current_tab == 2 and HAS_SYSMAP:
        sm_layout = _cc_sysmap.build_sysmap_layout(_sysmap_state, tick_s)
        # Patch the sysmap footer with the shared tab bar
        footer = panel_footer(state, tick_s, current_tab)
        try:
            sm_layout["footer"].update(footer)
        except Exception:
            pass
        return sm_layout

    # Tabs 1 / 3 / 4 — bus view (agents+loomies not yet embedded, fall through to bus)
    layout = Layout()
    layout.split_column(
        Layout(name="body", ratio=1),
        Layout(name="footer", size=3),
    )
    layout["body"].split_row(
        Layout(name="left", ratio=3),
        Layout(name="right", ratio=2),
    )
    layout["body"]["left"].split_column(
        Layout(panel_rates(state),  name="rates", ratio=1),
        Layout(panel_stream(state), name="stream", ratio=1),
    )
    layout["body"]["right"].split_column(
        Layout(panel_talkers(state),  name="talkers",  ratio=2),
        Layout(panel_alerts(state),   name="alerts",   ratio=2),
        Layout(panel_signals(state),  name="signals",  ratio=1),
    )
    layout["footer"].update(panel_footer(state, tick_s, current_tab))
    return layout


# ─── main loop ─────────────────────────────────────────────────────────────
def main() -> int:
    global SAGA_STALE_S, SAGA_KILL_S, SAGA_REQUIRE_START
    p = argparse.ArgumentParser(description="cc-bus-dashboard — immersive nervous-bus view")
    p.add_argument("--log", type=Path, default=DEFAULT_LOG,
                   help=f"path to JSONL log (default: {DEFAULT_LOG})")
    p.add_argument("--tick", type=float, default=1.5,
                   help="repaint interval in seconds (default: 1.5)")
    p.add_argument("--max-history", type=int, default=2000,
                   help="bootstrap from last N lines of existing log (default: 2000)")
    p.add_argument("--once", action="store_true",
                   help="render one frame and exit (for screenshot/test use)")
    p.add_argument("--saga-stale", type=int, default=SAGA_STALE_S,
                   help=f"dim sagas idle past N seconds (default: {SAGA_STALE_S})")
    p.add_argument("--saga-kill", type=int, default=SAGA_KILL_S,
                   help=f"drop sagas idle past N seconds (default: {SAGA_KILL_S})")
    p.add_argument("--saga-allow-implicit-open", action="store_true",
                   help="open sagas on ANY event with cycle_id (legacy behavior); "
                        "default requires explicit .start/.opened/.created/.cycle.start")
    p.add_argument("--schemas", type=Path, default=DEFAULT_SCHEMAS_DIR,
                   help=f"schemas/ dir for silent-channel detection "
                        f"(default: {DEFAULT_SCHEMAS_DIR}; pass empty/missing path to disable)")
    p.add_argument("--tab", type=int, default=1, choices=[1, 2, 3, 4],
                   help="start on tab N (1=bus 2=sysmap 3=agents 4=loomies)")
    args = p.parse_args()

    # Apply tunables to module globals so existing code paths pick them up.
    SAGA_STALE_S = args.saga_stale
    SAGA_KILL_S  = args.saga_kill
    SAGA_REQUIRE_START = not args.saga_allow_implicit_open

    state = State(log_path=args.log)
    state.expected_channels = load_expected_channels(args.schemas)
    try:
        import redis as _r
        state._redis = _r.Redis.from_url("redis://localhost:6379", decode_responses=True,
                                          socket_timeout=1, socket_connect_timeout=1)
        state._redis.ping()
    except Exception:
        state._redis = None

    # bootstrap from existing log so the dashboard isn't empty on startup.
    if args.log.exists():
        try:
            with args.log.open("r", encoding="utf-8", errors="replace") as f:
                lines = f.readlines()
            state.last_bucket_epoch = int(time.time()) // BUCKET_SECONDS
            for line in lines[-args.max_history:]:
                line = line.strip()
                if line:
                    ingest_event(state, line, historical=True)
        except Exception:
            pass

    open_log(state)

    console = Console()

    if args.once:
        console.print(build_layout(state, args.tick))
        return 0

    # ── keyboard reader thread ──────────────────────────────────────────────
    current_tab = args.tab
    quit_flag   = threading.Event()
    _key_lock   = threading.Lock()

    def _keyboard_reader() -> None:
        nonlocal current_tab
        fd = sys.stdin.fileno()
        try:
            old = termios.tcgetattr(fd)
        except termios.error:
            return  # not a tty (pipe/redirect) — skip
        try:
            tty.setcbreak(fd)
            while not quit_flag.is_set():
                if select.select([sys.stdin], [], [], 0.2)[0]:
                    ch = os.read(fd, 1).decode("utf-8", errors="ignore")
                    if ch == "\x1b":
                        # ESC alone? Could be a quit. ESC followed by another
                        # byte within 50ms is an Alt+X / CSI sequence — drain
                        # & ignore. Prevents zellij-locked-mode Alt+[ etc.
                        # leaking through and killing the dashboard.
                        if _esc_is_alt_sequence(
                            poll_fn=lambda t: bool(select.select([sys.stdin], [], [], t)[0]),
                            read_fn=lambda n: os.read(fd, n),
                        ):
                            continue             # swallow — never quit on Alt-anything
                        quit_flag.set()
                        break
                    if ch in ("q", "\x03"):       # q / Ctrl+C
                        quit_flag.set()
                        break
                    if ch in ("1", "2", "3", "4"):
                        with _key_lock:
                            current_tab = int(ch)
                    # m9d keybinds
                    if ch == "/":
                        with _key_lock:
                            state.filter_glob = ""
                            # next keypresses build the glob (handled in main loop via stdin)
                    if ch == "z":
                        with _key_lock:
                            state.zoom_idx = (state.zoom_idx + 1) % 3
                            state.BUCKET_SECONDS = [300, 3600, 86400][state.zoom_idx]
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)

    kb_thread = threading.Thread(target=_keyboard_reader, daemon=True, name="cc-kb")
    kb_thread.start()

    try:
        last_sysmap_version = -1
        last_rendered_tab   = -1
        with Live(build_layout(state, args.tick, current_tab),
                  console=console,
                  refresh_per_second=1,
                  screen=True) as live:
            while not quit_flag.is_set():
                new_lines = read_new_lines(state)
                for line in new_lines:
                    ingest_event(state, line)
                state.roll_buckets_to(int(time.time()))
                state.thresholds.refresh()
                with _key_lock:
                    tab = current_tab
                tab_changed = (tab != last_rendered_tab)
                if tab == 2 and HAS_SYSMAP:
                    cur_ver = _sysmap_state.version
                    if tab_changed or cur_ver != last_sysmap_version:
                        live.update(build_layout(state, args.tick, tab))
                        last_sysmap_version = cur_ver
                    last_rendered_tab = tab
                else:
                    live.update(build_layout(state, args.tick, tab))
                    last_rendered_tab = tab
                time.sleep(args.tick)
    except KeyboardInterrupt:
        pass
    except Exception as e:
        console.print(f"[red]dashboard crashed:[/] {e}")
        return 1
    finally:
        quit_flag.set()

    return 0


if __name__ == "__main__":
    sys.exit(main())
