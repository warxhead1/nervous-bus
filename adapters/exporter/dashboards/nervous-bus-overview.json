{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Top 10 channels by ev/s (60s rolling)",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "cps", "min": 0},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "expr": "topk(10, nbus_events_per_second)",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active sessions (by agent_type)",
      "type": "stat",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"}},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum by (agent_type) (nbus_session_active)",
          "legendFormat": "{{agent_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Autobench iteration score (latest per session)",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "nbus_autobench_iteration_score",
          "legendFormat": "{{session_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "AHE prediction outcomes",
      "type": "piechart",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "pieType": "donut",
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}
      },
      "targets": [
        {
          "expr": "sum by (outcome) (nbus_autobench_ahe_outcome_total)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["nervous-bus", "autobench"],
