#!/usr/bin/env bash
# nervous — publish events to the nervous-bus from any shell.
#
# Wraps `zellij pipe -p nervous-bus -n <channel>` with CloudEvents-lite
# envelope construction. Reads payload as JSON from arg or stdin.
#
# Usage:
#   nervous publish <channel> '<json-payload>'
#   echo '<json>' | nervous publish <channel>
#   nervous publish tengine.session.frame --subject silo_racing_X '{"fps":47.3}'
#   nervous tail tengine.session            # subscribe (requires plugin running)
#   nervous schemas                         # list known channels (repo + user-home)
#   nervous schemas --cluster autobench     # filter by taxonomy cluster
#   nervous schemas --search prediction     # substring match on channel name
#   nervous schemas --clusters              # list clusters + counts (CHANNELS.md)
#   nervous schema install <path>           # install private/custom schema to user-home
#   nervous schema list                     # list user-home schemas
#   nervous setup                           # bootstrap NERVOUS_HOME directory structure
#   nervous dlq                             # show recent dead-letter events
#   nervous dlq --since 1h --reason malformed_json
#   nervous dlq --json                      # raw JSONL for piping into jq
#   nervous trace <trace-id>                # causal chain: events sharing a traceparent
#   nervous trace <trace-id> --json         # raw envelopes for piping into jq
#
# Env:
#   NERVOUS_SOURCE   override source field (default: /<basename-cwd>)
#   NERVOUS_TRACEPARENT  W3C trace-context string added to the envelope as the
#                    CloudEvents `traceparent` extension (docs/TRACE-CONTEXT.md).
#                    Format: 00-<32 hex>-<16 hex>-<2 hex>. Invalid values are
#                    dropped with a stderr warning, never published.
#   NERVOUS_PLUGIN   plugin name (default: nervous-bus)
#   NERVOUS_HOME     user-level config + private schema overlay
#                    (default: ~/.config/nervous-bus)
#   NERVOUS_PYTHON   interpreter used for Redis XADD + schema validation
#                    (default: python3 on PATH)
#   NERVOUS_STRICT_REDIS       1 = non-zero exit when Redis delivery fails
#   NERVOUS_STRICT_VALIDATION  1 = non-zero exit when schema validation is
#                    SKIPPED (jsonschema module absent). Default fail-soft:
#                    publish prints a machine-readable degradation marker on
#                    stdout (delivery=file-only validation=skipped ...) and a
#                    one-time stderr warning, but still exits 0.

set -euo pipefail

CMD="${1:-help}"
shift || true

# User-level home directory — holds private/custom schemas and config.
# Schemas here override repo schemas for the same channel name.
NERVOUS_HOME="${NERVOUS_HOME:-$HOME/.config/nervous-bus}"

PLUGIN="${NERVOUS_PLUGIN:-nervous-bus}"

ulid() {
    # ULID-ish: timestamp-ms (10 chars) + 16 random base32 chars
    local ts ms hex
    ts=$(date +%s)
    ms=$(( $(date +%N | sed 's/^0*//') / 1000000 ))
    hex=$(head -c 10 /dev/urandom | od -An -vtx1 | tr -d ' \n' | tr 'a-f' 'A-F')
    printf "%010d%s\n" "$ts$ms" "${hex:0:16}"
}

iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

cmd_help() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    exit 0
}

# Write a CloudEvents envelope to Redis Streams (nbus:<channel> + nbus:all).
#
# The envelope has already been schema-validated by cmd_publish at this point;
# this function is pure transport (not a producer bypassing the SDK). Delivery
# is idempotent: an event id is XADD'd at most once across the live publish path
# and the redis-mirror backstop, gated by a short-lived claim key
# (nbus:dedup:<id>, claim-before-publish, fail-open).
#
# Tries python-redis first (fast, pipelined); falls back to redis-cli when no
# python interpreter on PATH carries the redis module — the systemd-service case
# (/usr/bin/python3 with no redis install) that previously made delivery a
# silent no-op. Pin the interpreter with $NERVOUS_PYTHON. Fail-soft: if Redis is
# unreachable the event is still durable in debug.jsonl and the mirror delivers
# it once Redis returns.
_nbus_redis_xadd() {
    local raw_json="$1"
    [[ "${NERVOUS_NO_REDIS:-0}" == "1" ]] && return 0
    if _nbus_xadd_python "$raw_json"; then return 0; fi
    if _nbus_xadd_rediscli "$raw_json"; then return 0; fi
    # Neither path reached Redis. The event is still durable in debug.jsonl, but
    # do NOT fail silently — surface it so service-context delivery gaps are
    # visible (the root of the gzsv/bt0a "exit 0 on silent loss" bug). Producers
    # that need at-least-once delivery set NERVOUS_STRICT_REDIS=1 to get a
    # non-zero exit instead of the fail-soft default.
    echo "nervous: WARNING: Redis delivery failed for publish (event durable in debug.jsonl)" >&2
    [[ "${NERVOUS_STRICT_REDIS:-0}" == "1" ]] && return 1
    return 0
}

# Primary delivery via python-redis. Exits 0 on delivery (or a confirmed dup),
# non-zero on any failure (missing redis module, unreachable Redis) so the
# caller falls back to redis-cli.
_nbus_xadd_python() {
    "${NERVOUS_PYTHON:-python3}" - "$1" <<'PYEOF' 2>/dev/null
import sys, os, json
try:
    import redis as _r
    raw = sys.argv[1]
    env = json.loads(raw)
    ch = env.get('type', '')
    if not ch:
        sys.exit(0)
    eid = env.get('id', '')
    fields = {
        '_raw':      raw,
        'type':      ch,
        'source':    env.get('source', ''),
        'timestamp': env.get('time', ''),
        'event_id':  eid,
    }
    url = os.environ.get('NERVOUS_REDIS_URL', 'redis://localhost:6379')
    r = _r.Redis.from_url(url, socket_connect_timeout=1, socket_timeout=1)
    # Idempotent claim — if the mirror (or a prior call) already delivered this
    # id, skip the XADD. Fail-open: a dedup-infra error must not block delivery.
    if eid:
        try:
            if r.set('nbus:dedup:' + eid, '1', nx=True, ex=600) is None:
                sys.exit(0)
        except Exception:
            pass
    p = r.pipeline(transaction=False)
    p.xadd(f'nbus:{ch}', fields, maxlen=10000, approximate=True)
    p.xadd('nbus:all',   fields, maxlen=50000, approximate=True)
    p.execute()
    sys.exit(0)
except SystemExit:
    raise
except Exception:
    sys.exit(1)
PYEOF
}

# Fallback delivery via redis-cli. Used when the python path can't reach Redis —
# typically a systemd service whose python3 lacks the redis MODULE (the
# interpreter itself, and stdlib json, are still present). Field extraction uses
# python stdlib json rather than jq, which service hosts frequently lack and
# whose absence previously made this fallback a silent no-op. Mirrors the python
# path's idempotent claim semantics.
_nbus_xadd_rediscli() {
    command -v redis-cli >/dev/null 2>&1 || return 1
    local raw="$1" url ch src ts id parsed
    url="${NERVOUS_REDIS_URL:-redis://localhost:6379}"
    parsed="$("${NERVOUS_PYTHON:-python3}" - "$raw" 2>/dev/null <<'PYEOF'
import sys, json
try:
    d = json.loads(sys.argv[1])
except Exception:
    sys.exit(1)
print(d.get('type', ''))
print(d.get('source', ''))
print(d.get('time', ''))
print(d.get('id', ''))
PYEOF
)" || return 1
    { IFS= read -r ch; IFS= read -r src; IFS= read -r ts; IFS= read -r id; } <<<"$parsed"
    [[ -z "$ch" ]] && return 0
    # Idempotent claim. SET..NX returns "OK" when claimed, nil (empty) when the
    # key already exists. A non-zero exit means Redis is unreachable — report
    # failure so the event stays in debug.jsonl for the mirror to deliver.
    if [[ -n "$id" ]]; then
        local _claim _rc
        if _claim="$(redis-cli -u "$url" SET "nbus:dedup:$id" 1 NX EX 600 2>/dev/null)"; then _rc=0; else _rc=$?; fi
        [[ $_rc -ne 0 ]] && return 1
        [[ "$_claim" != "OK" ]] && return 0
    fi
    redis-cli -u "$url" XADD "nbus:$ch" MAXLEN '~' 10000 '*' \
        _raw "$raw" type "$ch" source "$src" timestamp "$ts" event_id "$id" >/dev/null 2>&1 || return 1
    redis-cli -u "$url" XADD nbus:all MAXLEN '~' 50000 '*' \
        _raw "$raw" type "$ch" source "$src" timestamp "$ts" event_id "$id" >/dev/null 2>&1 || true
    return 0
}

cmd_publish() {
    # Parse flags before positional args so Go can call:  nervous publish --json
    # (stdin = complete CloudEvents envelope, no channel arg needed).
    # Or: nervous publish <channel> [--subject S] <payload>
    local subject="" pass_through=false
    while [[ $# -gt 0 && "$1" == --* ]]; do
        case "$1" in
            --subject) subject="$2"; shift 2 ;;
            --json)    pass_through=true; shift ;;
            --)        shift; break ;;
            --*)       echo "unknown flag: $1" >&2; return 2 ;;
        esac
    done

    # Determine channel from args or parsed payload. For --json we MUST read
    # stdin exactly once (a second `cat` later would get an empty string, since
    # stdin is already drained) — capture the full envelope into `payload` here
    # and derive the channel from it.
    local channel="" payload=""
    if [[ "$pass_through" == "true" ]]; then
        payload="$(cat)"
        channel="$(printf '%s' "$payload" | python3 -c "import json,sys; print(json.load(sys.stdin).get('type',''))")" || {
            echo "nervous publish --json: failed to parse event type from payload" >&2; return 2
        }
    else
        channel="${1:?usage: nervous publish <channel> [--subject S] [--json] <payload>}"
    fi

    # ── uwb: allowlist enforcement via nervous.toml ─────────────────────────────────
    # Walk up from PWD to find nearest nervous.toml; parse [channels] with glob matching.
    # Permissive (warn once) if no TOML found. Exit 2 on violation.
    if [[ "$pass_through" == "false" && "${NERVOUS_SKIP_ALLOWLIST:-}" != "1" ]]; then
        local toml_path=""
        local dir="$PWD"
        while [[ "$dir" != "/" && -z "$toml_path" ]]; do
            if [[ -f "$dir/nervous.toml" ]]; then
                toml_path="$dir/nervous.toml"
            else
                dir="$(dirname "$dir")"
            fi
        done

        if [[ -n "$toml_path" ]]; then
            local allowed=false
            allowed=$(python3 - "$toml_path" "$channel" <<'PYEOF'
import sys
from fnmatch import fnmatch

toml_path = sys.argv[1]
channel = sys.argv[2]

try:
    import tomllib
except ImportError:
    import toml as tomllib

with open(toml_path, "rb") as f:
    cfg = tomllib.load(f)

patterns = cfg.get("channels", [])
if not patterns:
    print("allow")  # absent [channels] → permissive
    sys.exit(0)

for pat in patterns:
    if fnmatch(channel, pat):
        print("allow")
        sys.exit(0)

print("deny")
PYEOF
)
            if [[ "$allowed" != "allow" ]]; then
                echo "ERROR: channel '$channel' not in allowlist" >&2
                echo "  nervous.toml: $toml_path" >&2
                echo "  add '$channel' to [channels] or remove nervous.toml" >&2
                NERVOUS_SKIP_ALLOWLIST=1 NERVOUS_NO_ZELLIJ=1 NERVOUS_NO_REDIS=1 \
                    nervous publish bus.dead_letter "$(python3 -c "import json; print(json.dumps({
                        'failure_reason': 'allowlist_violation',
                        'original_type': '$channel',
                        'original_source': '${NERVOUS_SOURCE:-/unknown}',
                    }))")" >/dev/null 2>&1 || true
                return 2
            fi
        else
            # Permissive: no TOML found — warn once per session (tracked via tmp marker)
            local warn_marker="/tmp/nervous-no-toml-warned"
            if [[ ! -f "$warn_marker" ]]; then
                echo "nervous: WARNING: no nervous.toml found, publish not allowlist-checked" >&2
                touch "$warn_marker"
            fi
        fi
    fi

    # --json: payload was already read from stdin above (single read).
    # Normal: channel in $1, payload in $2.
    if [[ "$pass_through" != "true" ]]; then
        payload="$2"
    fi

    # --json: caller already built the full CloudEvents envelope (Go side).
    # Pass it straight through — no re-enveloping, preserves Go's source/id/time/type.
    if [[ "$pass_through" == "true" ]]; then
        local log="${NERVOUS_DEBUG_LOG:-$HOME/.cache/nervous-bus/debug.jsonl}"
        mkdir -p "$(dirname "$log")"
        local event_channel
        event_channel="$(printf '%s' "$payload" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('type',''), end='')")" 2>/dev/null || true
        if [[ -z "$event_channel" ]]; then
            echo "nervous publish --json: failed to parse event type from payload" >&2
            return 2
        fi
        local _log_max=524288000
        if [[ -f "$log" ]]; then
            local _log_size
            _log_size=$(stat -c%s "$log" 2>/dev/null || echo 0)
            if (( _log_size > _log_max )); then mv -f "$log" "${log}.1" 2>/dev/null || true; fi
        fi
        printf '%s\n' "$payload" >> "$log"
        _nbus_redis_xadd "$payload"
        if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1 && [[ "${NERVOUS_NO_ZELLIJ:-0}" != "1" ]]; then
            # Fire-and-forget: zellij pipe is best-effort legacy compat. File-tail + Redis
            # Streams are the primary subscriber paths; don't pay the 1s timeout tax inline.
            ( printf '%s' "$payload" | timeout 1 zellij pipe -p "$PLUGIN" -n "$event_channel" 2>/dev/null ) &
            disown
        fi
        return 0
    fi

    local source="${NERVOUS_SOURCE:-/$(basename "$PWD")}"
    local id; id="$(ulid)"
    local time; time="$(iso_now)"
    local subj_field=""
    if [[ -n "$subject" ]]; then
        subj_field="\"subject\":$(printf '%s' "$subject" | jq -R .),"
    fi
    # CloudEvents distributed-tracing extension (docs/TRACE-CONTEXT.md).
    # Envelope-level, optional; malformed values are dropped, not published.
    local trace_field=""
    if [[ -n "${NERVOUS_TRACEPARENT:-}" ]]; then
        if [[ "${NERVOUS_TRACEPARENT}" =~ ^00-[0-9a-f]{32}-[0-9a-f]{16}-[0-9a-f]{2}$ ]]; then
            trace_field="\"traceparent\":\"${NERVOUS_TRACEPARENT}\","
        else
            echo "nervous: WARNING: NERVOUS_TRACEPARENT is not a valid W3C traceparent, dropping it" >&2
        fi
    fi
    local envelope
    envelope=$(printf '{"specversion":"1.0","id":"%s","source":%s,"type":"%s",%s%s"time":"%s","datacontenttype":"application/json","data":%s}' \
        "$id" \
        "$(printf '%s' "$source" | jq -R .)" \
        "$channel" \
        "$subj_field" \
        "$trace_field" \
        "$time" \
        "$payload")
    local log="${NERVOUS_DEBUG_LOG:-$HOME/.cache/nervous-bus/debug.jsonl}"
    mkdir -p "$(dirname "$log")"

    # ── Schema validation ────────────────────────────────────────────────────────
    # Skip validation when NBUS_SKIP_VALIDATION=1 (high-frequency pre-validated publishers).
    if [[ "${NBUS_SKIP_VALIDATION:-0}" != "1" ]]; then
        local _repo_schema_dir
        _repo_schema_dir="$(dirname "$(readlink -f "$0")")/../../schemas"
        # User-home schemas take precedence over repo schemas (overlay pattern).
        local _schema_file=""
        if [[ -f "${NERVOUS_HOME}/schemas/${channel}.json" ]]; then
            _schema_file="${NERVOUS_HOME}/schemas/${channel}.json"
        elif [[ -f "${_repo_schema_dir}/${channel}.json" ]]; then
            _schema_file="${_repo_schema_dir}/${channel}.json"
        fi
        if [[ -n "$_schema_file" ]]; then
            # Pass envelope + schema path as argv so stdin is unambiguous (no heredoc conflict).
            # Use `if` to run the validator — this suppresses set -e for the tested command,
            # so a non-zero exit from the validator doesn't abort the script.
            local _validation_result _exit_code
            local _vtmp; _vtmp=$(mktemp)
            if "${NERVOUS_PYTHON:-python3}" -c '
import sys, json
# Exit 4 = the jsonschema MODULE is absent on this interpreter (the
# systemd-service /usr/bin/python3 case). This is a validation-SKIPPED
# degradation, distinct from a payload violation — surface it loudly so a
# Rust/Go caller can detect that publish ran without schema enforcement.
try:
    import jsonschema
except ImportError as e:
    print("module_missing:" + str(e), end="")
    sys.exit(4)
schema_file = sys.argv[1]
envelope_raw = sys.argv[2]
try:
    envelope = json.loads(envelope_raw)
    schema   = json.load(open(schema_file))
except Exception as e:
    print("parse_error:" + str(e), end="")
    sys.exit(1)
is_envelope_schema = "specversion" in schema.get("required", [])
subject = envelope if is_envelope_schema else envelope.get("data", {})
try:
    jsonschema.validate(subject, schema)
    print("ok", end="")
    sys.exit(0)
except jsonschema.ValidationError as e:
    print("violation:" + str(e.message)[:500], end="")
    sys.exit(2)
except Exception as e:
    print("error:" + str(e), end="")
    sys.exit(3)
' "$_schema_file" "$envelope" >"$_vtmp" 2>&1; then
                _exit_code=0
            else
                _exit_code=$?
            fi
            _validation_result=$(cat "$_vtmp"); rm -f "$_vtmp"
            if [[ $_exit_code -eq 2 ]]; then
                # Exit 2 = explicit ValidationError — real schema violation, dead-letter it.
                local _detail="${_validation_result#violation:}"
                local _excerpt
                _excerpt="$(printf '%s' "$envelope" | cut -c1-500)"
                local _dl_payload
                _dl_payload=$(python3 -c "import json,sys; print(json.dumps({
                    'failure_reason': 'schema_violation',
                    'original_type': sys.argv[1],
                    'original_source': sys.argv[2],
                    'schema_violation_detail': sys.argv[3],
                    'original_payload_excerpt': sys.argv[4],
                }))" "$channel" "$source" "$_detail" "$_excerpt" 2>/dev/null)
                if [[ -n "$_dl_payload" ]]; then
                    local _dl_id; _dl_id="$(ulid)"
                    local _dl_time; _dl_time="$(iso_now)"
                    local _dl_envelope
                    _dl_envelope=$(printf '{"specversion":"1.0","id":"%s","source":%s,"type":"bus.dead_letter","time":"%s","datacontenttype":"application/json","data":%s}' \
                        "$_dl_id" \
                        "$(printf '%s' "$source" | jq -R .)" \
                        "$_dl_time" \
                        "$_dl_payload")
                    printf '%s\n' "$_dl_envelope" >> "$log"
                    NBUS_SKIP_VALIDATION=1 _nbus_redis_xadd "$_dl_envelope"
                fi
                echo "[nbus schema] validation failed for $channel: $_detail" >&2
                return 2
            elif [[ $_exit_code -eq 4 ]]; then
                # Exit 4 = jsonschema MODULE absent → validation was SKIPPED.
                # Mirror the Redis-XADD degradation contract (NERVOUS_STRICT_REDIS):
                # this is a silent-loss class bug (gzsv/bt0a). The event is still
                # durable in debug.jsonl, but the publish ran WITHOUT schema
                # enforcement — surface it so a Rust/Go caller can react instead of
                # seeing a clean exit 0.
                #   1) machine-readable marker on stdout (parseable by callers);
                #   2) loud, one-time stderr warning;
                #   3) opt-in non-zero exit via NERVOUS_STRICT_VALIDATION=1.
                echo "delivery=file-only validation=skipped reason=jsonschema_module_missing channel=${channel}"
                local _vwarn_marker="/tmp/nervous-no-jsonschema-warned"
                if [[ ! -f "$_vwarn_marker" ]]; then
                    echo "nervous: WARNING: jsonschema module missing on ${NERVOUS_PYTHON:-python3} — schema validation SKIPPED for this publish (set NERVOUS_PYTHON to an interpreter with jsonschema, or install it). Events still durable in debug.jsonl." >&2
                    touch "$_vwarn_marker" 2>/dev/null || true
                fi
                if [[ "${NERVOUS_STRICT_VALIDATION:-0}" == "1" ]]; then
                    echo "[nbus schema] strict mode: aborting publish for $channel (validation unavailable)" >&2
                    return 4
                fi
            elif [[ $_exit_code -ne 0 ]]; then
                # Exit 1 = parse/import error, exit 3 = unexpected validator error.
                # These are infrastructure failures (not a missing jsonschema
                # module, which is exit 4 above), not payload violations. Warn and
                # allow through — never dead-letter.
                echo "[nbus schema] validator error for $channel (exit $_exit_code): ${_validation_result}" >&2
            fi
        else
            echo "[nbus warn] no schema for type: $channel" >&2
        fi
    fi
    # ────────────────────────────────────────────────────────────────────────────

    # Always tee to debug log (durable, easy to subscribe via tail -F).
    # Rotate at 500 MB: mv → .1, open fresh. Consumers detect inode change and
    # reopen — same mechanism used by redis-mirror and cc-bus-dashboard.
    local _log_max=524288000
    if [[ -f "$log" ]]; then
        local _log_size
        _log_size=$(stat -c%s "$log" 2>/dev/null || echo 0)
        if (( _log_size > _log_max )); then
            mv -f "$log" "${log}.1" 2>/dev/null || true
        fi
    fi
    printf '%s\n' "$envelope" >> "$log"
    # Also write directly to Redis Streams — eliminates the file→mirror→Redis hop.
    _nbus_redis_xadd "$envelope"

    # If we're in a real zellij session AND the socket is reachable, also pipe
    # to the plugin — fire-and-forget so a stalled/missing plugin doesn't block.
    # File-tail + Redis Streams are the primary subscriber paths; this remains
    # only as best-effort legacy compat for the WASM plugin path.
    if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
        if [[ "${NERVOUS_NO_ZELLIJ:-0}" != "1" ]]; then
            ( printf '%s' "$envelope" | timeout 1 zellij pipe -p "$PLUGIN" -n "$channel" 2>/dev/null ) &
            disown
        fi
    fi
}

cmd_subscribers() {
    if [[ -z "${ZELLIJ:-}" ]]; then
        echo "nervous subscribers requires a Zellij session" >&2
        return 1
    fi
    local out
    out="$(printf '{"pid":%d}' "$$" | zellij pipe -p "$PLUGIN" -n "subscribers" 2>/dev/null)" || {
        echo "nervous subscribers: plugin unreachable" >&2
        return 1
    }
    echo "$out"
}

cmd_tail() {
    local channel="${1:?usage: nervous tail <channel>}"
    if [[ -z "${ZELLIJ:-}" ]]; then
        local log="${NERVOUS_DEBUG_LOG:-$HOME/.cache/nervous-bus/debug.jsonl}"
        tail -f "$log" | grep --line-buffered -F "\"type\":\"$channel\""
        return
    fi
    # In zellij: send subscribe request to plugin
    printf '{"plugin_id":%d}' "$$" | zellij pipe -p "$PLUGIN" -n "subscribe:$channel"
    echo "subscribed pid=$$ to $channel (plugin will fan out via pipe_message_to_plugin)"
}

# Causal-chain reader for the traceparent extension (docs/TRACE-CONTEXT.md):
# every envelope whose traceparent contains the given trace-id, oldest first.
# This is the consumption surface that makes the field worth writing (the
# no-three-quarter-loops rule) — a trace with no reader would be plumbing.
cmd_trace() {
    local as_json=false trace=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) as_json=true; shift ;;
            *)      trace="$1"; shift ;;
        esac
    done
    [[ -n "$trace" ]] || { echo "usage: nervous trace <trace-id> [--json]" >&2; return 2; }
    local log="${NERVOUS_DEBUG_LOG:-$HOME/.cache/nervous-bus/debug.jsonl}"
    # Include the rotated window (debug.jsonl.1) so a chain that straddles a
    # rotation still reads as one trace. Rotated file first = oldest first.
    "${NERVOUS_PYTHON:-python3}" - "$trace" "$as_json" "$log" <<'PYEOF'
import json, sys
trace, as_json, log = sys.argv[1], sys.argv[2] == "true", sys.argv[3]
events = []
for path in (log + ".1", log):
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                if trace not in line:
                    continue
                try:
                    env = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if trace in env.get("traceparent", ""):
                    events.append(env)
    except OSError:
        continue
events.sort(key=lambda e: e.get("time", ""))
if not events:
    print(f"no events with traceparent containing {trace!r}", file=sys.stderr)
    sys.exit(1)
if as_json:
    for env in events:
        print(json.dumps(env))
else:
    for env in events:
        print(f'{env.get("time","-"):20}  {env.get("type","-"):45}  {env.get("source","-"):20}  {env.get("id","-")}')
PYEOF
}

cmd_schemas() {
    # Discovery over the channel taxonomy (see schemas/CHANNELS.md).
    #   nervous schemas                       list all channels (repo + user-home)
    #   nervous schemas --cluster autobench   only channels in a cluster
    #   nervous schemas --search prediction   substring match on channel name
    #   nervous schemas --clusters            list cluster names + counts
    # Cluster classification mirrors tools/gen_channels_md.py (imported below so
    # the CLI and CHANNELS.md never drift).
    local cluster="" search="" list_clusters=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cluster)  cluster="${2:?usage: nervous schemas --cluster <name>}"; shift 2 ;;
            --search)   search="${2:?usage: nervous schemas --search <keyword>}"; shift 2 ;;
            --clusters) list_clusters=true; shift ;;
            -h|--help)
                sed -n 's/^    #   //p' < <(grep -A4 'Discovery over the channel' "$0") 2>/dev/null
                echo "usage: nervous schemas [--cluster <name>] [--search <kw>] [--clusters]" >&2
                return 0 ;;
            *) echo "nervous schemas: unknown flag $1" >&2; return 2 ;;
        esac
    done

    local repo_dir
    repo_dir="$(dirname "$(readlink -f "$0")")/../../schemas"
    if [[ ! -d "$repo_dir" ]]; then
        echo "no schemas directory: $repo_dir" >&2
        exit 2
    fi
    local user_dir="${NERVOUS_HOME}/schemas"

    # Plain list (no filters): preserve the original behaviour exactly.
    if [[ -z "$cluster" && -z "$search" && "$list_clusters" == "false" ]]; then
        find "$repo_dir" -maxdepth 1 -name '*.json' -printf '%f\n' 2>/dev/null | sort
        if [[ -d "$user_dir" ]] && [[ -n "$(find "$user_dir" -maxdepth 1 -name '*.json' 2>/dev/null)" ]]; then
            echo ""
            echo "# user schemas (${user_dir}):"
            find "$user_dir" -maxdepth 1 -name '*.json' -printf '%f\n' 2>/dev/null | sort
        fi
        return 0
    fi

    # Filtered / cluster modes — delegate classification to the generator module
    # so the rules are defined in exactly one place.
    local tools_dir
    tools_dir="$(dirname "$(readlink -f "$0")")/../../tools"
    CLUSTER_FILTER="$cluster" SEARCH_FILTER="$search" LIST_CLUSTERS="$list_clusters" \
    GEN_MODULE_DIR="$tools_dir" \
    "${NERVOUS_PYTHON:-python3}" - "$repo_dir" "$user_dir" <<'PYEOF'
import os, sys
from pathlib import Path

sys.path.insert(0, os.environ["GEN_MODULE_DIR"])
try:
    from gen_channels_md import classify, CLUSTERS, NAME_RE
except Exception as e:
    print(f"nervous schemas: cannot load taxonomy rules: {e}", file=sys.stderr)
    sys.exit(2)

repo_dir = Path(sys.argv[1])
user_dir = Path(sys.argv[2])
cluster = os.environ.get("CLUSTER_FILTER", "").strip()
search = os.environ.get("SEARCH_FILTER", "").strip().lower()
list_clusters = os.environ.get("LIST_CLUSTERS", "false") == "true"

# Gather channels: repo first, then user-home overlay (mark overlay).
channels = []  # (channel, is_user)
seen = set()
for d, is_user in ((repo_dir, False), (user_dir, True)):
    if not d.is_dir():
        continue
    for p in sorted(d.glob("*.json")):
        ch = p.name[:-len(".json")]
        if ch in seen:
            continue
        seen.add(ch)
        channels.append((ch, is_user))

if list_clusters:
    counts = {name: 0 for name, _ in CLUSTERS}
    for ch, _ in channels:
        counts[classify(ch)] += 1
    for name, desc in CLUSTERS:
        print(f"{name:<20} {counts[name]:>4}  {desc}")
    sys.exit(0)

# Resolve a fuzzy cluster name (case-insensitive substring against cluster names).
target_cluster = None
if cluster:
    names = [name for name, _ in CLUSTERS]
    exact = [n for n in names if n.lower() == cluster.lower()]
    partial = [n for n in names if cluster.lower() in n.lower()]
    if exact:
        target_cluster = exact[0]
    elif len(partial) == 1:
        target_cluster = partial[0]
    elif len(partial) > 1:
        print(f"ambiguous --cluster '{cluster}': matches {partial}", file=sys.stderr)
        sys.exit(2)
    else:
        print(f"unknown cluster '{cluster}'. Known: {names}", file=sys.stderr)
        sys.exit(2)

out = []
for ch, is_user in channels:
    if target_cluster and classify(ch) != target_cluster:
        continue
    if search and search not in ch.lower():
        continue
    out.append((ch, is_user))

if not out:
    what = []
    if target_cluster:
        what.append(f"cluster={target_cluster}")
    if search:
        what.append(f"search={search}")
    print(f"no channels match {' '.join(what)}", file=sys.stderr)
    sys.exit(0)

for ch, is_user in out:
    tag = " (user)" if is_user else ""
    warn = " [!naming]" if not NAME_RE.match(ch) else ""
    print(f"{ch}{tag}{warn}")
PYEOF
}

cmd_setup() {
    local install_hooks=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --install-hooks) install_hooks=true; shift ;;
            *) echo "nervous setup: unknown flag $1" >&2; return 2 ;;
        esac
    done

    echo "nervous-bus setup — bootstrapping user home: ${NERVOUS_HOME}"
    mkdir -p "${NERVOUS_HOME}/schemas"
    mkdir -p "${NERVOUS_HOME}/adapters"

    if [[ "$install_hooks" == "true" ]]; then
        local repo_root
        repo_root="$(dirname "$(readlink -f "$0")")/../../"
        local hook_src="${repo_root}/sdk/shell/hooks/pre-commit-gitleaks.sh"
        local hook_dst="${repo_root}/.git/hooks/pre-commit"
        if [[ -f "$hook_src" ]]; then
            cp "$hook_src" "$hook_dst" && chmod +x "$hook_dst"
            echo "installed: .git/hooks/pre-commit (gitleaks)"
        fi
    fi
    if [[ ! -f "${NERVOUS_HOME}/config.toml" ]]; then
        cat > "${NERVOUS_HOME}/config.toml" << 'TOML'
# nervous-bus user configuration (~/.config/nervous-bus/config.toml)
#
# NERVOUS_HOME layout:
#   schemas/    — private/custom schema overlay (loaded alongside repo schemas;
#                 same channel name here overrides the repo version)
#   adapters/   — private adapter source + systemd unit files that should not
#                 live in the public repo (e.g. bridges to private services)
#
# Install schemas with:  nervous schema install <path>
# List adapters with:    nervous adapter list
#
# [redis]
# url = "redis://localhost:6379"
TOML
        echo "created: ${NERVOUS_HOME}/config.toml"
    fi
    echo ""
    echo "  schema overlay  : ${NERVOUS_HOME}/schemas/"
    echo "  private adapters: ${NERVOUS_HOME}/adapters/"
    echo ""
    echo "  nervous schema install <file-or-dir>   install private schemas"
    echo "  nervous adapter list                   list installed private adapters"
    echo ""
    echo "Add to shell profile to override the default location:"
    echo "  export NERVOUS_HOME=${NERVOUS_HOME}"
}

cmd_adapter() {
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            local adap_dir="${NERVOUS_HOME}/adapters"
            if [[ -d "$adap_dir" ]]; then
                find "$adap_dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort
            else
                echo "(no private adapters — run 'nervous setup' first)" >&2
            fi
            ;;
        *)
            echo "usage: nervous adapter list" >&2; return 1
            ;;
    esac
}

cmd_schema() {
    local sub="${1:-help}"; shift || true
    case "$sub" in
        install)
            local target="${1:?usage: nervous schema install <file-or-dir>}"
            mkdir -p "${NERVOUS_HOME}/schemas"
            if [[ -d "$target" ]]; then
                local count=0
                for f in "$target"/*.json; do
                    [[ -f "$f" ]] || continue
                    cp "$f" "${NERVOUS_HOME}/schemas/"
                    echo "installed: $(basename "$f")"
                    count=$(( count + 1 ))
                done
                echo "$count schema(s) → ${NERVOUS_HOME}/schemas/"
            elif [[ -f "$target" ]]; then
                cp "$target" "${NERVOUS_HOME}/schemas/"
                echo "installed: $(basename "$target") → ${NERVOUS_HOME}/schemas/"
            else
                echo "nervous schema install: not found: $target" >&2; return 2
            fi
            ;;
        list)
            local user_dir="${NERVOUS_HOME}/schemas"
            if [[ -d "$user_dir" ]] && [[ -n "$(find "$user_dir" -maxdepth 1 -name '*.json' 2>/dev/null)" ]]; then
                find "$user_dir" -maxdepth 1 -name '*.json' -printf '%f\n' 2>/dev/null | sort
            else
                echo "(no user schemas — run 'nervous setup' then 'nervous schema install')" >&2
            fi
            ;;
        remove)
            local name="${1:?usage: nervous schema remove <channel-name>}"
            local f="${NERVOUS_HOME}/schemas/${name%.json}.json"
            if [[ -f "$f" ]]; then
                rm "$f" && echo "removed: $(basename "$f")"
            else
                echo "not found in user schemas: $f" >&2; return 2
            fi
            ;;
        *)
            echo "usage: nervous schema install <file-or-dir> | list | remove <name>" >&2; return 1
            ;;
    esac
}

# IMPORTANT: the bus.dead_letter ring is ephemeral (256 entries per channel,
# in-memory in the WASM plugin). `nervous dlq` reads the durable JSONL log
# instead, which captures every dead-letter ever emitted on this host.
# It is NOT a queue — there are no acks, redelivery, or guaranteed retention.
cmd_dlq() {
    local log="${NERVOUS_DEBUG_LOG:-$HOME/.cache/nervous-bus/debug.jsonl}"
    local since="" reason="" mode="pretty"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since)   since="$2"; shift 2 ;;
            --reason)  reason="$2"; shift 2 ;;
            --json)    mode="json"; shift ;;
            -h|--help)
                cat <<HELP
nervous dlq — surface bus.dead_letter events from the durable JSONL log.

Usage:
  nervous dlq                       show last 50 dead letters, formatted
  nervous dlq --since 1h            only show entries from the last hour
  nervous dlq --reason malformed_json
                                    filter by failure_reason
  nervous dlq --json                raw JSONL (pipe into jq)

NOTE: The plugin's dead-letter ring is in-memory (256 entries per channel).
      \`nervous dlq\` reads the JSONL log instead, which is durable. Older
      entries persist on disk but the in-plugin ring may have evicted them.
HELP
                return 0
                ;;
            *) echo "nervous dlq: unknown flag $1" >&2; return 2 ;;
        esac
    done
    [[ -f "$log" ]] || { echo "no log: $log" >&2; return 2; }

    # Resolve --since to an epoch cutoff (e.g. 1h, 30m, 2d)
    local cutoff_epoch=0
    if [[ -n "$since" ]]; then
        local n="${since//[^0-9]/}" unit="${since//[0-9]/}"
        [[ -z "$n" ]] && { echo "bad --since: $since" >&2; return 2; }
        case "$unit" in
            s|"") cutoff_epoch=$(( $(date +%s) - n )) ;;
            m)    cutoff_epoch=$(( $(date +%s) - n*60 )) ;;
            h)    cutoff_epoch=$(( $(date +%s) - n*3600 )) ;;
            d)    cutoff_epoch=$(( $(date +%s) - n*86400 )) ;;
            *)    echo "bad --since unit: $unit (use s/m/h/d)" >&2; return 2 ;;
        esac
    fi

    REASON_FILTER="$reason" CUTOFF_EPOCH="$cutoff_epoch" MODE="$mode" \
    python3 - "$log" <<'PYEOF'
import json, os, sys, datetime as dt

log = sys.argv[1]
mode = os.environ.get('MODE', 'pretty')
reason_filter = os.environ.get('REASON_FILTER', '')
cutoff_epoch = int(os.environ.get('CUTOFF_EPOCH', '0'))

def parse_ts(s):
    try:
        return int(dt.datetime.fromisoformat(s.replace('Z','+00:00')).timestamp())
    except Exception:
        return 0

hits = []
with open(log) as f:
    for line in f:
        line = line.strip()
        if not line or '"bus.dead_letter"' not in line:
            continue
        try:
            e = json.loads(line)
        except Exception:
            continue
        if e.get('type') != 'bus.dead_letter':
            continue
        if cutoff_epoch and parse_ts(e.get('time','')) < cutoff_epoch:
            continue
        d = e.get('data') or {}
        if reason_filter and d.get('failure_reason','') != reason_filter:
            continue
        hits.append(e)

if mode == 'json':
    for e in hits:
        print(json.dumps(e))
    sys.exit(0)

if not hits:
    print('\033[2mno dead letters found\033[0m', file=sys.stderr)
    sys.exit(0)

R = '\033[0m'; DIM = '\033[2m'; BOLD = '\033[1m'
RED = '\033[31m'; YEL = '\033[33m'; CYN = '\033[36m'; MAG = '\033[35m'

reason_color = {
    'malformed_json':         RED,
    'missing_required_field': YEL,
    'unknown_channel':        MAG,
    'schema_violation':       YEL,
    'payload_too_large':      YEL,
    'delivery_failed':        RED,
}
print(f"{BOLD}nervous dlq{R}  {DIM}{len(hits)} dead letters{R}  "
      f"{DIM}(ring is ephemeral; log is durable){R}")
print(DIM + ('─' * 70) + R)

# Show last 50, newest last (so it scrolls naturally in a terminal)
for e in hits[-50:]:
    t = (e.get('time','') or '')[11:19]
    d = e.get('data') or {}
    reason = d.get('failure_reason','?')
    orig = d.get('original_type','?')
    excerpt = (d.get('original_payload_excerpt','') or '').replace('\n',' ')[:60]
    src = (e.get('source','') or '').lstrip('/').split('/')[-1][:14]
    col = reason_color.get(reason, DIM)
    print(f"{DIM}{t}{R}  {col}{reason:<22}{R}  "
          f"{CYN}{orig:<26}{R}  {DIM}{src:<14}{R}  {excerpt}")

# Reason histogram footer
from collections import Counter
hist = Counter((e.get('data') or {}).get('failure_reason','?') for e in hits)
print(DIM + ('─' * 70) + R)
parts = [f"{reason_color.get(k,'')}{k}{R}={v}" for k,v in hist.most_common()]
print(f"{DIM}by reason:{R}  " + '  '.join(parts))
PYEOF
}

cmd_pattern() {
    local sub="${1:-list}"; shift || true

    case "$sub" in
        list)
            ~/.pyenv/versions/3.11.13/bin/python3 - <<'PYEOF'
import redis, sys
try:
    r = redis.Redis.from_url('redis://localhost:6379', decode_responses=True)
    entries = r.xrange('nbus:draft-beads', count=20)
    if not entries:
        print('no draft signals pending')
    else:
        for eid, data in entries:
            sid = data.get('signal_id', eid)[-12:]
            st  = data.get('signal_type', '?')
            conf = data.get('confidence', '?')
            proj = data.get('project_hint', '')
            desc = data.get('description', '')[:60]
            print(f'{sid}  {st:<12} conf={conf}  [{proj}]  {desc}')
        print()
        print('nervous pattern accept <signal_id> [notes]')
        print('nervous pattern reject <signal_id> [notes]')
except Exception as e:
    print(f'error reading drafts: {e}', file=sys.stderr)
PYEOF
            ;;
        accept|reject)
            local signal_id="${1:?signal_id required}"; shift || true
            local notes="${*}"
            local verdict="$sub"
            local payload
            payload=$(python3 -c "import json,sys; print(json.dumps({'signal_id':sys.argv[1],'verdict':sys.argv[2],'draft_bead_id':None,'notes':sys.argv[3]}))" "$signal_id" "$verdict" "$notes")
            nervous publish bus.pattern.feedback.v1 "$payload"
            echo "feedback recorded: $verdict $signal_id"
            ;;
        *)
            echo "usage: nervous pattern list|accept|reject [args]" >&2
            return 1
            ;;
    esac
}

case "$CMD" in
    publish) cmd_publish "$@" ;;
    tail)    cmd_tail "$@" ;;
    subscribers) cmd_subscribers "$@" ;;
    schemas) cmd_schemas "$@" ;;
    schema)  cmd_schema "$@" ;;
    adapter) cmd_adapter "$@" ;;
    setup)   cmd_setup "$@" ;;
    dlq)     cmd_dlq "$@" ;;
    trace)   cmd_trace "$@" ;;
    pattern) cmd_pattern "$@" ;;
    help|-h|--help) cmd_help ;;
    *) echo "unknown command: $CMD" >&2; cmd_help ;;
esac
