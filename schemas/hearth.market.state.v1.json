{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/hearth.market.state.v1.json",
  "title": "hearth.market.state v1",
  "description": "Market regime state as consumed by hearth from tachyonos signals. Published by hearth when it processes tachyonos events so other consumers can react to hearth's market interpretation.",
  "type": "object",
  "required": ["ts", "regime_label", "confidence"],
  "properties": {
    "ts": {"type": "string", "format": "date-time"},
    "regime_label": {"type": "string", "description": "e.g. bull, bear, neutral, volatile"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "signal_type": {"type": "string"},
    "source_channel": {"type": "string", "description": "tachyonos channel that triggered this"},
    "automation_triggered": {"type": "string", "description": "any home automation scene triggered"},
    "raw_signal": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
