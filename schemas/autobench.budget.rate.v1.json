{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/autobench.budget.rate.v1.json",
  "title": "autobench.budget.rate v1",
  "description": "Request-rate budget guard threshold-crossing events. Emitted at 50%, 80%, 100% of the sliding-window request rate cap (e.g. 15000 requests / 5 hours for MiniMax coding plan). Source: /autobench.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": {"type": "string", "const": "1.0"},
    "id": {"type": "string"},
    "source": {"type": "string"},
    "type": {"type": "string", "const": "autobench.budget.rate.v1"},
    "datacontenttype": {"type": "string", "const": "application/json"},
    "time": {"type": "string", "format": "date-time"},
    "data": {
      "type": "object",
      "required": [
        "session_id",
        "current_count",
        "max_requests",
        "window_seconds",
        "fraction_used",
        "action",
        "warned_at_threshold"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "description": "ULID identifying the autobench session for bus correlation."
        },
        "current_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of recorded requests currently within the sliding window."
        },
        "max_requests": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum allowed requests within the window before halt (after safety margin applied)."
        },
        "window_seconds": {
          "type": "number",
          "minimum": 0.0,
          "description": "Sliding-window length in seconds. 18000s = 5h for MiniMax coding plan."
        },
        "fraction_used": {
          "type": "number",
          "minimum": 0.0,
          "description": "current_count / max_requests. Range [0, +inf); >= 1.0 means halt."
        },
        "time_until_available": {
          "type": "number",
          "minimum": 0.0,
          "description": "Seconds until the oldest in-window timestamp expires and a slot opens. 0 when under cap."
        },
        "action": {
          "type": "string",
          "enum": ["warning", "halt"],
          "description": "'warning' for 50/80% thresholds; 'halt' for 100% (cap reached)."
        },
        "warned_at_threshold": {
          "type": "number",
          "enum": [0.5, 0.8, 1.0],
          "description": "Which threshold tripped this event."
        },
        "reason": {
          "type": "string",
          "description": "Human-readable explanation."
        }
      }
    }
  }
}
