{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/kernel.candidate.evaluated.v1.json",
  "title": "kernel.candidate.evaluated.v1 v1",
  "description": "Autobench FunSearch kernel \u2014 kernel.candidate.evaluated.v1 event. Union across all 8 domains; domain-discriminated via data.domain. Source: /autobench/kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/kernel"
    },
    "type": {
      "type": "string",
      "const": "kernel.candidate.evaluated.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "fitness",
        "generation",
        "island",
        "run_id",
        "source"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "code_length": {
          "type": "integer"
        },
        "computation_time_ms": {
          "type": "number"
        },
        "domain": {
          "type": "string",
          "enum": [
            "sph",
            "sdf",
            "noise",
            "phase",
            "terrain",
            "thermal",
            "latent",
            "tsp",
            "svdag",
            "racing"
          ],
          "description": "Kernel domain discriminator."
        },
        "eikonal_score": {
          "type": "number"
        },
        "fitness": {
          "type": "number"
        },
        "fitness_variance": {
          "type": "number"
        },
        "generation": {
          "type": "integer"
        },
        "harmonic_ratio": {
          "type": "number"
        },
        "instance_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "island": {
          "type": "integer"
        },
        "mean_grad_err": {
          "type": "number"
        },
        "mean_mse": {
          "type": "number"
        },
        "program_id": {
          "type": "string"
        },
        "raps_fitness": {
          "type": "number"
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "sign_change_density": {
          "type": "number"
        },
        "source": {
          "type": "string"
        },
        "spectral_beta": {
          "type": "number"
        },
        "ssim_fallback": {
          "type": "number"
        },
        "topology_score": {
          "type": "number"
        },
        "worst_fitness": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}
