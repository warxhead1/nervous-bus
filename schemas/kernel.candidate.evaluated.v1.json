{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/kernel.candidate.evaluated.v1.json",
  "title": "kernel.candidate.evaluated v1",
  "description": "Autobench FunSearch kernel — candidate.evaluated event. Domain-discriminated via data.domain. Source: /autobench/kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/kernel"
    },
    "type": {
      "type": "string",
      "const": "kernel.candidate.evaluated.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "run_id",
        "generation",
        "candidate_id",
        "island",
        "fitness",
        "fitness_variance",
        "worst_fitness",
        "source",
        "code_length",
        "computation_time_ms"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["sph", "sdf", "noise", "phase", "terrain", "thermal", "latent", "tsp"],
          "description": "Kernel domain discriminator."
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "candidate_id": {
          "type": "string"
        },
        "island": {
          "type": "integer"
        },
        "fitness": {
          "type": "number"
        },
        "fitness_variance": {
          "type": "number"
        },
        "worst_fitness": {
          "type": "number"
        },
        "source": {
          "type": "string"
        },
        "code_length": {
          "type": "integer"
        },
        "computation_time_ms": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}
