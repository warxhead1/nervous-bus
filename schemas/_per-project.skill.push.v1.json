{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "_per-project.skill.push.v1",
  "description": "Shared base schema. Concrete types: <project>.skill.push.v1. Emitted when an operator-approved proposal bead closes, pushing a skill bundle into matching profiles.",
  "type": "object",
  "required": ["project", "selector", "skill_name", "skill_bundle"],
  "properties": {
    "project":   { "type": "string" },
    "proposal_bead": { "type": "string", "description": "loom-XXXX id of the proposal bead that gated this push" },
    "selector": {
      "type": "object",
      "properties": {
        "class":    { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "skill_name":   { "type": "string" },
    "skill_bundle": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "content_base64"],
            "properties": {
              "path":           { "type": "string", "description": "Relative path under skills/<skill_name>/" },
              "content_base64": { "type": "string" },
              "mode":           { "type": "string", "description": "Optional unix mode, e.g. '0644'" }
            }
          }
        }
      }
    }
  }
}
