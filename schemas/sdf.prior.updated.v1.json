{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/sdf.prior.updated.v1.json",
  "title": "sdf.prior.updated v1",
  "description": "Emitted by SDFKernel when T-vectors are saved to the consolidated prior. Source: /autobench/sdf_kernel.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": {"type": "string", "const": "1.0"},
    "id": {"type": "string"},
    "source": {"type": "string", "const": "/autobench/sdf_kernel"},
    "type": {"type": "string", "const": "sdf.prior.updated.v1"},
    "datacontenttype": {"type": "string", "const": "application/json"},
    "time": {"type": "string", "format": "date-time"},
    "data": {
      "type": "object",
      "required": ["run_id", "kernel", "vectors_added", "total_vectors", "prior_path"],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying the kernel run that contributed the new T-vectors."
        },
        "kernel": {
          "type": "string",
          "description": "Kernel identifier (e.g. 'sdf')."
        },
        "vectors_added": {
          "type": "integer",
          "description": "Number of new T-vectors added in this update.",
          "minimum": 0
        },
        "total_vectors": {
          "type": "integer",
          "description": "Total number of T-vectors in the consolidated prior after the update.",
          "minimum": 0
        },
        "prior_path": {
          "type": "string",
          "description": "Filesystem path to the consolidated prior file."
        }
      }
    }
  }
}
