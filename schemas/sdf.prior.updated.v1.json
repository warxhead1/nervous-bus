{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/sdf.prior.updated.v1.json",
  "title": "sdf.prior.updated v1",
  "description": "Autobench sdf FunSearch kernel \u2014 prior.updated event. Source: /autobench/sdf_kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/sdf_kernel"
    },
    "type": {
      "type": "string",
      "const": "sdf.prior.updated.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "run_id",
        "kernel",
        "vectors_added",
        "total_vectors",
        "prior_path"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "kernel": {
          "type": "string"
        },
        "vectors_added": {
          "type": "integer"
        },
        "total_vectors": {
          "type": "integer"
        },
        "prior_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
