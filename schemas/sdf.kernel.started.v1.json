{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/sdf.kernel.started.v1.json",
  "title": "sdf.kernel.started v1",
  "description": "Emitted when the SDF FunSearch kernel begins a run. Source: /autobench/sdf_kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/sdf_kernel"
    },
    "type": {
      "type": "string",
      "const": "sdf.kernel.started.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "run_id",
        "instances",
        "n_islands",
        "population_per_island",
        "generations",
        "migration_interval"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "instances": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "SDF benchmark instance names being evaluated (e.g. 'gyroid', 'round_box', 'twisted_torus')."
        },
        "n_islands": {
          "type": "integer",
          "minimum": 1
        },
        "population_per_island": {
          "type": "integer",
          "minimum": 1
        },
        "generations": {
          "type": "integer",
          "minimum": 1
        },
        "migration_interval": {
          "type": "integer",
          "minimum": 1
        },
        "sandbox_type": {
          "type": "string",
          "description": "Isolation tier executing untrusted candidate code (e.g. 'gvisor', 'subprocess')."
        },
        "git_commit": {
          "type": "string",
          "description": "Short git SHA of the autobench source at run start."
        },
        "plateau_generations": {
          "type": [
            "integer",
            "null"
          ]
        },
        "temperature": {
          "type": "number"
        },
        "plateau_hint": {
          "type": "boolean"
        }
      }
    }
  }
}