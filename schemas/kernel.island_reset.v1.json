{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/kernel.island_reset.v1.json",
  "title": "kernel.island_reset v1",
  "description": "Autobench FunSearch kernel — island_reset event. Domain-discriminated via data.domain. Source: /autobench/kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/kernel"
    },
    "type": {
      "type": "string",
      "const": "kernel.island_reset.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "run_id",
        "generation",
        "n_islands_culled",
        "pre_reset_best_fitness",
        "plateau_count"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["sph", "sdf", "noise", "phase", "terrain", "thermal", "latent", "tsp", "svdag", "racing"],
          "description": "Kernel domain discriminator."
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "n_islands_culled": {
          "type": "integer"
        },
        "pre_reset_best_fitness": {
          "type": "number"
        },
        "plateau_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  }
}
