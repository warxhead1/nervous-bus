{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/autobench.invalidation.v1.json",
  "title": "autobench.invalidation v1",
  "description": "Emitted when a scope key is re-distilled and prior events are auto-deactivated.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "autobench.invalidation.v1"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": ["scope_key", "count_deactivated", "reason"],
      "properties": {
        "scope_key": {
          "type": "string",
          "minLength": 1
        },
        "count_deactivated": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}