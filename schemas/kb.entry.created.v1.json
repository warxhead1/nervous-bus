{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kb.entry.created.v1",
  "title": "KB Entry Created",
  "description": "Emitted by kb ingest when a new vault entry is written. Currently silent — this schema defines what the event SHOULD contain once kb ingest is updated to emit it. Primary consumers: hearth-api (counter), deer-flow (awareness of new knowledge).",
  "type": "object",
  "required": ["entry_id", "title", "project", "source_type", "confidence"],
  "properties": {
    "entry_id":    { "type": "string", "format": "uuid" },
    "title":       { "type": "string", "maxLength": 200 },
    "project":     { "type": "string" },
    "category":    { "type": "string", "enum": ["research", "design", "handoff", "plan", "reference", "log"] },
    "source_type": { "type": "string", "enum": ["deer-flow-research", "deer-flow-guidance", "tengine-session", "test-result", "manual", "agent-generated", "bead-outcome"] },
    "confidence":  { "type": "number", "minimum": 0, "maximum": 1 },
    "trace_uri":   { "type": "string", "description": "deer-flow://<thread>, bd://<bead>, tengine-session://<dir>" },
    "tags":        { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "file":        { "type": "string", "description": "Absolute path to the vault markdown file" }
  }
}
