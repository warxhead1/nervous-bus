{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/kernel.completed.v1.json",
  "title": "kernel.completed v1",
  "description": "Autobench FunSearch kernel — kernel.completed event. Domain-discriminated via data.domain. Source: /autobench/kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/kernel"
    },
    "type": {
      "type": "string",
      "const": "kernel.completed.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "run_id",
        "total_generations",
        "stop_reason",
        "llm_requests",
        "best_program",
        "history"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["sph", "sdf", "noise", "phase", "terrain", "thermal", "latent", "tsp"],
          "description": "Kernel domain discriminator."
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "total_generations": {
          "type": "integer"
        },
        "stop_reason": {
          "type": "string"
        },
        "llm_requests": {
          "type": "integer",
          "description": "Cumulative LLM requests this run (MiniMax billing unit is requests)."
        },
        "best_program": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "fitness": {
              "type": "number"
            },
            "island": {
              "type": "integer"
            },
            "generation": {
              "type": "integer"
            },
            "source": {
              "type": "string"
            },
            "sph_code": {
              "type": "string"
            }
          },
          "description": "Best program summary at run end (null if the run produced none)."
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
