{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/noise.candidate.evaluated.v1.json",
  "title": "noise.candidate.evaluated v1",
  "description": "Autobench noise FunSearch kernel \u2014 candidate.evaluated event. Source: /autobench/noise_kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/noise_kernel"
    },
    "type": {
      "type": "string",
      "const": "noise.candidate.evaluated.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "run_id",
        "program_id",
        "island",
        "generation",
        "fitness",
        "source",
        "spectral_beta",
        "harmonic_ratio",
        "raps_fitness",
        "ssim_fallback"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "program_id": {
          "type": "string"
        },
        "island": {
          "type": "integer"
        },
        "generation": {
          "type": "integer"
        },
        "fitness": {
          "type": "number"
        },
        "source": {
          "type": "string"
        },
        "spectral_beta": {
          "type": "number"
        },
        "harmonic_ratio": {
          "type": "number"
        },
        "raps_fitness": {
          "type": "number"
        },
        "ssim_fallback": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}
