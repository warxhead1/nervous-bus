{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/kernel.best_fitness_improved.v1.json",
  "title": "kernel.best_fitness_improved v1",
  "description": "Autobench FunSearch kernel — best_fitness_improved event. Domain-discriminated via data.domain. Source: /autobench/kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/kernel"
    },
    "type": {
      "type": "string",
      "const": "kernel.best_fitness_improved.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "run_id",
        "generation",
        "best_fitness",
        "improvement_delta",
        "best_program_id",
        "best_island"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["sph", "sdf", "noise", "phase", "terrain", "thermal", "latent", "tsp", "svdag", "racing"],
          "description": "Kernel domain discriminator."
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "best_fitness": {
          "type": "number",
          "description": "Best fitness this generation (domain-specific; higher = better)."
        },
        "improvement_delta": {
          "type": "number"
        },
        "best_program_id": {
          "type": "string"
        },
        "best_island": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  }
}
