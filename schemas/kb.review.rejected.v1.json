{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kb.review.rejected.v1",
  "title": "KB Review Rejected",
  "description": "Emitted by `kb review reject <id>` when a human reviewer refuses a proposed vault entry. The entry remains in vault but does not receive the approval confidence boost.",
  "type": "object",
  "required": ["entry_id", "rejection_reason", "reviewed_by", "reviewed_at"],
  "properties": {
    "entry_id":         { "type": "string", "format": "uuid" },
    "title":            { "type": "string", "maxLength": 200 },
    "project":          { "type": "string" },
    "rejection_reason": { "type": "string", "maxLength": 1000 },
    "reviewed_by":      { "type": "string" },
    "reviewed_at":      { "type": "string", "format": "date-time" }
  }
}
