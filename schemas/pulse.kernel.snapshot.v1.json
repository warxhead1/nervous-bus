{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/pulse.kernel.snapshot.v1.json",
  "title": "pulse.kernel.snapshot v1",
  "description": "Low-frequency coalesced rollup of kernel FunSearch progress so phones/TUIs never drink the per-candidate firehose. Emitted by autobench at most ~once/generation (or every 1-2s, whichever is slower). Source: /autobench/pulse.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/pulse"
    },
    "type": {
      "type": "string",
      "const": "pulse.kernel.snapshot.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "domain",
        "run_id",
        "generation",
        "best_fitness"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["sph", "sdf", "noise", "phase", "terrain", "thermal", "latent", "tsp"],
          "description": "Kernel domain discriminator."
        },
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "best_fitness": {
          "type": "number",
          "description": "Best fitness this snapshot covers (domain-specific; higher = better)."
        },
        "mean_fitness": {
          "type": "number",
          "description": "Mean population fitness across this snapshot window."
        },
        "islands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "island_id",
              "best_fitness",
              "status"
            ],
            "properties": {
              "island_id": {
                "type": "integer"
              },
              "best_fitness": {
                "type": "number"
              },
              "status": {
                "type": "string",
                "enum": ["active", "reset", "plateau"]
              }
            },
            "additionalProperties": false
          }
        },
        "budget": {
          "type": "object",
          "properties": {
            "requests_used": {
              "type": "integer"
            },
            "requests_cap": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "plateau": {
          "type": "boolean"
        },
        "window_ms": {
          "type": "integer",
          "description": "Coalescing window (ms) this snapshot covers."
        },
        "event_count": {
          "type": "integer",
          "description": "How many raw events were coalesced into this snapshot."
        }
      },
      "additionalProperties": false
    }
  }
}
