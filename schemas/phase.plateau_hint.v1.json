{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/phase.plateau_hint.v1.json",
  "title": "phase.plateau_hint v1",
  "description": "Autobench phase FunSearch kernel \u2014 plateau_hint event. Source: /autobench/phase_kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/phase_kernel"
    },
    "type": {
      "type": "string",
      "const": "phase.plateau_hint.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "run_id",
        "generation",
        "plateau_count",
        "best_fitness",
        "hint_preview"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "plateau_count": {
          "type": "integer"
        },
        "best_fitness": {
          "type": "number",
          "description": "Best fitness this generation (domain-specific; higher = better)."
        },
        "hint_preview": {
          "type": "string",
          "description": "First 200 chars of the strategic plateau hint injected into the prompt."
        }
      },
      "additionalProperties": false
    }
  }
}
