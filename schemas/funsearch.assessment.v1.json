{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "funsearch.assessment.v1",
  "description": "Post-run observer assessment: MiniMax structural analysis of top evolved programs.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "const": "1.0" },
    "id": { "type": "string" },
    "source": { "type": "string" },
    "type": { "type": "string", "const": "funsearch.assessment.v1" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["kernel", "run_id", "fitness", "metadata"],
      "properties": {
        "kernel": { "type": "string", "enum": ["sdf", "noise", "tsp"] },
        "run_id": { "type": "string" },
        "fitness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "render_type": { "type": "string", "const": "assessment" },
        "metadata": {
          "type": "object",
          "properties": {
            "synthesis": { "type": "string", "description": "MiniMax cross-program verdict (truncated)" },
            "n_assessed": { "type": "integer" },
            "top_fitness": {
              "type": "array",
              "items": { "type": "number" },
              "description": "Fitness of assessed programs in rank order"
            }
          }
        }
      }
    }
  }
}
