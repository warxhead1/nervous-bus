{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/bus.dispatch.recycle.skipped.v1.json",
  "title": "bus.dispatch.recycle.skipped v1",
  "description": "A task that was marked for recycle was skipped because a waiter (active execution) already holds the lock. Emitted by hearth-loom's recycle dispatch loop when a task is due for recycle but an active execution is already in progress. Source: /hearth-loom.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": {"type": "string", "const": "1.0"},
    "id": {"type": "string"},
    "source": {"type": "string", "const": "/hearth-loom"},
    "type": {"type": "string", "const": "bus.dispatch.recycle.skipped.v1"},
    "datacontenttype": {"type": "string", "const": "application/json"},
    "time": {"type": "string", "format": "date-time"},
    "data": {
      "type": "object",
      "required": ["execution_id", "task_id", "project_path", "queued_for_ms", "reason"],
      "properties": {
        "execution_id": {
          "type": "string",
          "description": "UUID of the execution that was skipped"
        },
        "task_id": {
          "type": "string",
          "description": "Bead/task identifier (e.g. loom-xxx)"
        },
        "project_path": {
          "type": "string",
          "description": "Absolute path to the project directory"
        },
        "queued_for_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Milliseconds the task was queued before being skipped"
        },
        "reason": {
          "type": "string",
          "enum": ["waiter_active"],
          "description": "Why the recycle was skipped"
        }
      }
    }
  }
}