{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nervous-bus/schemas/latent.generation.completed.v1.json",
  "title": "latent.generation.completed v1",
  "description": "Autobench latent FunSearch kernel \u2014 generation.completed event. Source: /autobench/latent_kernel.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "const": "/autobench/latent_kernel"
    },
    "type": {
      "type": "string",
      "const": "latent.generation.completed.v1"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "required": [
        "run_id",
        "generation",
        "best_fitness",
        "best_island",
        "mean_pop_fitness",
        "gen_seconds",
        "eval_seconds",
        "llm_requests",
        "fitness_std",
        "code_diversity",
        "island_reset_fired"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "ULID identifying this kernel run."
        },
        "generation": {
          "type": "integer"
        },
        "best_fitness": {
          "type": "number",
          "description": "Best fitness this generation (domain-specific; higher = better)."
        },
        "best_island": {
          "type": "integer"
        },
        "mean_pop_fitness": {
          "type": "number"
        },
        "gen_seconds": {
          "type": "number"
        },
        "eval_seconds": {
          "type": "number"
        },
        "llm_requests": {
          "type": "integer",
          "description": "Cumulative LLM requests this run (MiniMax billing unit is requests)."
        },
        "fitness_std": {
          "type": "number",
          "description": "Population fitness standard deviation \u2014 leading indicator of premature convergence."
        },
        "code_diversity": {
          "type": "number",
          "description": "Mean pairwise Jaccard code-token distance across active programs (0=identical, 1=disjoint)."
        },
        "island_reset_fired": {
          "type": "boolean",
          "description": "Whether a plateau-driven island reset fired this generation."
        }
      },
      "additionalProperties": false
    }
  }
}
